---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
---

<BaseLayout title="Newsletter - OpenModeration" description="Subscribe to the OpenModeration newsletter for monthly updates on content moderation, DSA compliance, and product releases.">
  <section class="bg-gradient-to-b from-brand-50 to-white py-20">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold tracking-tight text-surface-900 sm:text-5xl">Stay updated</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-surface-500">
        Get the latest on content moderation, DSA compliance, and OpenModeration &mdash; delivered monthly.
      </p>
    </div>
  </section>

  <section class="border-t border-surface-100 bg-white py-20">
    <div class="mx-auto max-w-xl px-4 sm:px-6 lg:px-8">
      <form action="/api/subscribe" method="POST" class="flex flex-col gap-4 sm:flex-row">
        <label for="email" class="sr-only">Email address</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          placeholder="you@example.com"
          class="min-w-0 flex-1 rounded-lg border border-surface-300 bg-surface-50 px-4 py-3 text-surface-900 placeholder-surface-400 outline-hidden focus:border-brand-500 focus:ring-2 focus:ring-brand-200"
        />
        <button
          type="submit"
          class="inline-flex shrink-0 cursor-pointer items-center justify-center rounded-lg bg-brand-600 px-6 py-3 font-semibold text-white transition-all hover:bg-brand-700 focus:ring-2 focus:ring-brand-200 focus:outline-hidden"
        >
          Subscribe
        </button>
      </form>
    </div>
  </section>

  <section class="border-t border-surface-100 bg-surface-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-center text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">What subscribers get</h2>
      <div class="mt-12 grid gap-8 md:grid-cols-3">
        <div class="rounded-xl border border-surface-200 bg-white p-8 text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-brand-100 text-brand-600">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-surface-900">Monthly product updates</h3>
          <p class="mt-2 text-sm text-surface-500">New features, provider additions, performance benchmarks, and roadmap previews.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-white p-8 text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-brand-100 text-brand-600">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-surface-900">Moderation industry news</h3>
          <p class="mt-2 text-sm text-surface-500">AI moderation research, platform policy changes, and emerging best practices.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-white p-8 text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-brand-100 text-brand-600">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-surface-900">DSA compliance changes</h3>
          <p class="mt-2 text-sm text-surface-500">Regulatory updates, compliance guides, and practical tips for staying DSA-ready.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-surface-100 bg-white py-20">
    <div class="mx-auto max-w-2xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">Previous issues</h2>
      <p class="mt-4 text-lg text-surface-500">
        Catch up on past editions covering everything from DSA deep-dives to provider comparisons.
      </p>
      <a
        href="/blog"
        class="mt-8 inline-flex items-center gap-2 rounded-lg bg-brand-600 px-6 py-3 font-semibold text-white transition-all hover:bg-brand-700 focus:ring-2 focus:ring-brand-200 focus:outline-hidden"
      >
        Read the blog
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <CTASection />
</BaseLayout>