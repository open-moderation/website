---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Terms of Service — OpenModeration"
  description="Terms of Service for OpenModeration by Logora. Self-hosted (AGPL v3), cloud service, acceptable use, and liability terms."
  canonical="https://www.openmoderation.com/terms"
>
  <section class="bg-gradient-to-b from-brand-50 to-white py-20">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold tracking-tight text-surface-900 sm:text-5xl">Terms of Service</h1>
      <p class="mt-4 text-sm text-surface-400">Last updated: June 2026</p>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="space-y-8 text-sm leading-relaxed text-surface-600">

        <div>
          <h2 class="text-lg font-semibold text-surface-900">1. Introduction</h2>
          <p class="mt-3">
            These Terms of Service (&ldquo;Terms&rdquo;) govern your use of OpenModeration,
            provided by <strong class="text-surface-900">Logora</strong> (&ldquo;we&rdquo;, &ldquo;our&rdquo;, or &ldquo;us&rdquo;).
