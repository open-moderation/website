---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';

const posts = [
  {
    title: "DSA Compliance for Small and Medium Platforms: A Practical Guide",
    description: "How small and medium platforms can meet DSA requirements with open-source tools. Practical steps for compliance.",
    slug: "dsa-compliance-sme-guide",
    date: "2026-06-16",
    readTime: "8 min",
    tags: ["DSA", "compliance", "guide"],
  },
  {
    title: "Build vs Buy: Content Moderation Infrastructure Costs in 2026",
    description: "The true cost of building in-house moderation vs using OpenModeration. Engineering time, maintenance, and hidden costs analyzed.",
    slug: "build-vs-buy-moderation",
    date: "2026-06-14",
    readTime: "9 min",
    tags: ["comparison", "build-vs-buy"],
  },
  {
    title: "Google Perspective API Sunset: Migration Guide for Forums",
    description: "Google's Perspective API is sunsetting in late 2026. How to migrate your forum or community to an open-source alternative.",
    slug: "perspective-api-migration-guide",
    date: "2026-06-12",
    readTime: "7 min",
    tags: ["perspective", "migration", "guide"],
  },
  {
    title: "OpenAI Moderation vs Azure vs Llama Guard: A 2026 Comparison",
    description: "An objective comparison of the leading AI moderation providers. Performance, pricing, language coverage, and when to use each one.",
    slug: "openai-vs-azure-vs-llama-guard-comparison",
    date: "2026-06-10",
    readTime: "8 min",
    tags: ["comparison", "providers"],
  },
  {
    title: "DSA Compliance Made Simple with Open-Source Moderation",
    description: "How to meet EU Digital Services Act requirements using open-source tools. Audit trails, transparency reporting, and data sovereignty.",
    slug: "dsa-compliance-open-source-moderation",
    date: "2026-06-08",
    readTime: "6 min",
    tags: ["DSA", "compliance", "open-source"],
  },
  {
    title: "Content Moderation for AI Applications: A Developer's Guide",
    description: "How to implement input and output filtering for LLM-powered applications. Best practices for prompt injection prevention and content safety.",
    slug: "ai-content-moderation-developer-guide",
    date: "2026-06-05",
    readTime: "10 min",
    tags: ["AI", "LLM", "guide"],
  },
  {
    title: "Introducing OpenModeration: The Unified Moderation Platform",
    description: "We're building the open-source infrastructure layer for content moderation. One API, every provider, complete control.",
    slug: "introducing-OpenModeration",
    date: "2026-06-01",
    readTime: "5 min",
    tags: ["announcement", "open-source"],
  },
];
---

<BaseLayout title="Blog &mdash; OpenModeration" description="Articles about content moderation, DSA compliance, AI safety, and open-source infrastructure.">
  <section class="bg-gradient-to-b from-brand-50 to-white py-20">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold tracking-tight text-surface-900 sm:text-5xl">Blog</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-surface-500">
        Thoughts on content moderation, AI safety, DSA compliance, and building open-source infrastructure.
      </p>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="group rounded-xl border border-surface-200 bg-white p-6 transition hover:shadow-md">
            <div class="flex items-center gap-3 text-xs text-surface-400">
              <time datetime={post.date}>{post.date}</time>
              <span>&middot;</span>
              <span>{post.readTime} read</span>
              <span>&middot;</span>
              {post.tags.map((tag) => (
                <span class="rounded-full bg-surface-100 px-2 py-0.5 text-xs text-surface-500">{tag}</span>
              ))}
            </div>
            <h2 class="mt-3 text-xl font-bold text-surface-900 group-hover:text-brand-600">{post.title}</h2>
            <p class="mt-2 text-sm text-surface-500">{post.description}</p>
            <div class="mt-4 flex items-center gap-1 text-sm font-medium text-brand-600">
              Read more
              <svg class="h-3.5 w-3.5 transition group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>