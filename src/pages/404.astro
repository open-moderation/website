---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found"
  description="The page you're looking for doesn't exist."
><slot name="head-start" /><meta name="robots" content="noindex, nofollow" /><slot name="head-end" /></BaseLayout>
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <h1 class="text-6xl font-bold tracking-tight text-surface-900">404</h1>
      <p class="mx-auto mt-4 max-w-md text-lg text-surface-500">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="mt-8 flex items-center justify-center gap-4">
        <a href="/" class="rounded-lg bg-brand-900 px-6 py-3 text-sm font-semibold text-white shadow-sm">
          Back to home
        </a>
        <a href="/features" class="rounded-lg border border-surface-300 bg-white px-6 py-3 text-sm font-semibold text-surface-700">
          See features
        </a>
      </div>
    </div>
  </section>
</BaseLayout>