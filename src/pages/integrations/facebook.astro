---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
import FAQ from '../../components/FAQ.astro';

const pageJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Facebook Comment Moderation Platform — OpenModeration",
  "description": "Moderate Facebook Page comments and posts automatically. AI-powered moderation, no-code rules, and instant enforcement via the Facebook Graph API."
};

const faqItems = [
  {
    question: "How does Facebook comment moderation work?",
    answer: "Connect your Facebook Page via the Graph API. Comments are automatically ingested and analyzed by our AI engine. Based on your rules, toxic comments are hidden or deleted—no manual review needed."
  },
  {
    question: "Do I need to write code to set it up?",
    answer: "No. The setup is entirely configuration-based. Connect your Facebook Page in the dashboard, set your moderation rules using plain language or toggles, and you're live in minutes."
  },
  {
    question: "What types of content can Facebook moderate?",
    answer: "Comments, replies, and posts on your Facebook Page. The platform detects hate speech, harassment, spam, NSFW content, PII, scams, and more across 120+ languages."
  },
  {
    question: "How much does Facebook comment moderation cost?",
    answer: "OpenModeration is open source and free to self-host. Our cloud plan starts at a flat monthly rate with no hidden fees. You only pay for the AI provider calls you choose to use."
  },
];
---

<BaseLayout title="Facebook Comment Moderation Platform — OpenModeration" description="Moderate Facebook Page comments automatically with AI. No-code rules, 120+ languages, instant hide/delete via Graph API. The simplest Facebook moderation solution." canonical="https://www.openmoderation.com/integrations/facebook" jsonLd={pageJsonLd}>
  <section class="bg-gradient-to-b from-blue-50 to-white py-20">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-blue-100 text-blue-600">
        <svg class="h-8 w-8" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      </div>
      <h1 class="text-4xl font-bold tracking-tight text-surface-900 sm:text-5xl">Facebook Comment Moderation</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-surface-500">
        Protect your Facebook Page with AI-powered moderation. Set up in minutes, no code required.
      </p>
      <div class="mt-8 flex items-center justify-center gap-4">
        <a href="https://app.openmoderation.com/signup" class="inline-flex items-center gap-2 rounded-lg bg-brand-900 px-6 py-3 text-sm font-medium text-white shadow-sm hover:bg-brand-800">Try it for free</a>
        <a href="/how-it-works" class="inline-flex items-center gap-2 rounded-lg border border-surface-300 px-6 py-3 text-sm font-medium text-surface-700 hover:border-surface-900">How it works</a>
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">Simple moderation in 3 steps</h2>
        <p class="mt-4 text-lg text-surface-500">From zero to protected in minutes. No engineering team required.</p>
      </div>
      <div class="grid gap-8 md:grid-cols-3">
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-8 text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-brand-100 text-brand-600">
            <span class="text-xl font-bold">1</span>
          </div>
          <h3 class="text-lg font-semibold text-surface-900">Create your account</h3>
          <p class="mt-2 text-sm text-surface-500">Sign up for free on OpenModeration — no credit card, no commitment. Choose cloud or self-host.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-8 text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-brand-100 text-brand-600">
            <span class="text-xl font-bold">2</span>
          </div>
          <h3 class="text-lg font-semibold text-surface-900">Connect your Facebook Page</h3>
          <p class="mt-2 text-sm text-surface-500">Link your Facebook Page with your own credentials. The connector ingests comments and posts automatically.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-8 text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-brand-100 text-brand-600">
            <span class="text-xl font-bold">3</span>
          </div>
          <h3 class="text-lg font-semibold text-surface-900">Set rules and relax</h3>
          <p class="mt-2 text-sm text-surface-500">Define your moderation rules with plain language. Our AI enforces them automatically — hide, delete, or flag content.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-surface-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">What you can detect</h2>
        <p class="mt-4 text-lg text-surface-500">20+ pre-built detection models, trained on billions of labels.</p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">Toxicity</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">Hate speech</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">Harassment</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">Spam</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">NSFW</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">Scams & phishing</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">PII</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">Self-harm</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">Profanity</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">Sentiment</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">Sensitive topics</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">URL risks</span></div>
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">Why it's the simplest Facebook moderation solution</h2>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <h3 class="font-semibold text-surface-900">No code required</h3>
          <p class="mt-2 text-sm text-surface-500">Set up everything from the dashboard. Connect your page, write rules in plain English, and let AI handle the rest.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <h3 class="font-semibold text-surface-900">Your credentials, your control</h3>
          <p class="mt-2 text-sm text-surface-500">Use your own Facebook Page access token. We never store credentials in plaintext and you retain full ownership.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <h3 class="font-semibold text-surface-900">Auto-enforcement on Facebook</h3>
          <p class="mt-2 text-sm text-surface-500">Hide or delete violating comments directly through the Facebook Graph API. No manual moderation queue needed.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <h3 class="font-semibold text-surface-900">120+ languages</h3>
          <p class="mt-2 text-sm text-surface-500">Moderate comments in any language your community uses. Smart routing picks the best AI provider for each language.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <h3 class="font-semibold text-surface-900">Custom rules in plain language</h3>
          <p class="mt-2 text-sm text-surface-500">Write your moderation policy the way you'd explain it to a teammate. No prompt engineering or regex required.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <h3 class="font-semibold text-surface-900">Open source & self-hostable</h3>
          <p class="mt-2 text-sm text-surface-500">Deploy on your infrastructure with Docker. All data stays under your control. AGPL v3 licensed.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-surface-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <FAQ items={faqItems} title="Frequently asked questions about Facebook moderation" />
    </div>
  </section>

  <CTASection />
</BaseLayout>
