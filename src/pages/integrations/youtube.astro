---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTASection from '../../components/CTASection.astro';
import FAQ from '../../components/FAQ.astro';

const pageJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "YouTube Comment Moderation Platform — OpenModeration",
  "description": "Moderate YouTube comments at scale with AI. Auto-mark spam, hide toxic comments, and hold messages for review. The simplest YouTube comment moderation solution."
};

const faqItems = [
  {
    question: "How does YouTube comment moderation work?",
    answer: "Connect your YouTube channel via the YouTube Data API. Comments are ingested and analyzed by AI. Based on your rules, comments are marked as spam, hidden, or flagged for review."
  },
  {
    question: "Is this easy to set up?",
    answer: "Yes. The entire setup is done from the dashboard. Connect your YouTube channel, configure your moderation rules with simple toggles and plain language, and the platform starts protecting your videos immediately."
  },
  {
    question: "What can YouTube moderation detect?",
    answer: "Hate speech, harassment, spam, NSFW content, PII, scams, phishing, profanity, self-harm, sentiment, sensitive topics, and URL risks. 20+ models across 120+ languages."
  },
  {
    question: "Do I need technical skills to use it?",
    answer: "No. OpenModeration is designed for creators and community managers. Rules are configured in plain English from an intuitive dashboard. No coding required."
  },
  {
    question: "Can I review flagged comments before removing them?",
    answer: "Yes. Borderline cases can be sent to a manual review queue where your team approves or rejects them. Every action is logged for full transparency."
  },
];
---

<BaseLayout title="YouTube Comment Moderation Platform — OpenModeration" description="Moderate YouTube comments with AI. Auto-mark spam, hide toxic comments, 120+ languages. The simplest YouTube moderation solution for creators and brands." canonical="https://www.openmoderation.com/integrations/youtube" jsonLd={pageJsonLd}>
  <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Integrations", href: "/connectors" }, { label: "YouTube Moderation" }]} />
  <section class="bg-gradient-to-b from-red-50 to-white py-20">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-red-100 text-red-600">
        <svg class="h-8 w-8" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
      </div>
      <h1 class="text-4xl font-bold tracking-tight text-surface-900 sm:text-5xl">YouTube Comment Moderation</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-surface-500">
        Moderate YouTube comments at scale. AI-powered, no-code setup, works in minutes.
      </p>
      <div class="mt-8 flex items-center justify-center gap-4">
        <a href="https://app.openmoderation.com/signup" class="inline-flex items-center gap-2 rounded-lg bg-brand-900 px-6 py-3 text-sm font-medium text-white shadow-sm hover:bg-brand-800">Try it for free</a>
        <a href="/how-it-works" class="inline-flex items-center gap-2 rounded-lg border border-surface-300 px-6 py-3 text-sm font-medium text-surface-700 hover:border-surface-900">How it works</a>
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">Start moderating in 3 simple steps</h2>
        <p class="mt-4 text-lg text-surface-500">From setup to protection in minutes. No development work needed.</p>
      </div>
      <div class="grid gap-8 md:grid-cols-3">
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-8 text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-brand-100 text-brand-600">
            <span class="text-xl font-bold">1</span>
          </div>
          <h3 class="text-lg font-semibold text-surface-900">Create your account</h3>
          <p class="mt-2 text-sm text-surface-500">Sign up for free. No credit card required. Choose cloud or self-hosted deployment.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-8 text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-brand-100 text-brand-600">
            <span class="text-xl font-bold">2</span>
          </div>
          <h3 class="text-lg font-semibold text-surface-900">Connect YouTube</h3>
          <p class="mt-2 text-sm text-surface-500">Link your YouTube channel using your own Data API credentials. The connector ingests comments automatically.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-8 text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-brand-100 text-brand-600">
            <span class="text-xl font-bold">3</span>
          </div>
          <h3 class="text-lg font-semibold text-surface-900">Set rules and relax</h3>
          <p class="mt-2 text-sm text-surface-500">Define your rules with plain language. AI marks spam, hides toxicity, and flags edge cases for review automatically.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-surface-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">What the AI detects in your comments</h2>
        <p class="mt-4 text-lg text-surface-500">20+ pre-built models trained on billions of content labels.</p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">Toxicity</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">Hate speech</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">Harassment</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">Spam</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">NSFW</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">Scams & phishing</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">PII</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">Self-harm</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">Profanity</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">Sentiment</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">Sensitive topics</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">URL risks</span></div>
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">Why it's the simplest YouTube moderation solution</h2>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <h3 class="font-semibold text-surface-900">Zero code needed</h3>
          <p class="mt-2 text-sm text-surface-500">Everything is configured from the dashboard. No API development, no engineering time, no complex setup.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <h3 class="font-semibold text-surface-900">YouTube-native actions</h3>
          <p class="mt-2 text-sm text-surface-500">Mark comments as spam, hold for review, or hide them directly through the YouTube Data API. Works just like YouTube Studio — automated.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <h3 class="font-semibold text-surface-900">Handles any scale</h3>
          <p class="mt-2 text-sm text-surface-500">From 100 comments a day to 100,000. OpenModeration scales with your channel without breaking a sweat.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <h3 class="font-semibold text-surface-900">120+ languages</h3>
          <p class="mt-2 text-sm text-surface-500">Your global audience comments in many languages. One platform detects toxicity in all of them automatically.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <h3 class="font-semibold text-surface-900">Custom plain-language rules</h3>
          <p class="mt-2 text-sm text-surface-500">Write your moderation policy in plain English. The AI understands intent, not just keywords.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <h3 class="font-semibold text-surface-900">Auditable & transparent</h3>
          <p class="mt-2 text-sm text-surface-500">Every moderation decision is logged with full context. Open source and self-hostable for complete data control.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-surface-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <FAQ items={faqItems} title="Frequently asked questions about YouTube moderation" />
    </div>
  </section>

  <CTASection />
</BaseLayout>
