---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
import FAQ from '../../components/FAQ.astro';

const pageJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Instagram Content Moderation Platform — OpenModeration",
  "description": "Moderate Instagram comments and messages with AI. No-code setup, auto-hide toxic content, 120+ languages. The simplest Instagram moderation platform."
};

const faqItems = [
  {
    question: "How does Instagram comment moderation work?",
    answer: "Connect your Instagram account to OpenModeration. Comments and replies are automatically analyzed by AI. Toxic content is hidden or deleted based on your rules—no manual effort required."
  },
  {
    question: "Is it complicated to set up?",
    answer: "Not at all. The entire setup is done from the dashboard with no coding. Connect your Instagram account, choose your moderation rules, and the platform handles the rest. It takes minutes."
  },
  {
    question: "What does Instagram moderation detect?",
    answer: "The platform detects hate speech, harassment, spam, NSFW content, PII, scams, phishing, profanity, self-harm, and more. 20+ pre-built detection models cover 120+ languages."
  },
  {
    question: "Do I need coding skills to use OpenModeration for Instagram?",
    answer: "No. The platform is designed for non-technical users. Rules are set with plain language and toggle switches. The dashboard is intuitive and requires zero development work."
  },
  {
    question: "Is this better than Instagram's built-in moderation?",
    answer: "Yes. Instagram's built-in filters are limited to keyword blocking. OpenModeration uses context-aware AI that understands nuance, sarcasm, and conversation history. You also get custom rules, team review queues, and full audit trails."
  },
];
---

<BaseLayout title="Instagram Content Moderation Platform — OpenModeration" description="Moderate Instagram comments with AI. No-code rules, auto-hide toxic content, 120+ languages. The simplest Instagram moderation platform for creators and brands." canonical="https://www.openmoderation.com/integrations/instagram" jsonLd={pageJsonLd}>
  <section class="bg-gradient-to-b from-pink-50 to-white py-20">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-pink-100 text-pink-600">
        <svg class="h-8 w-8" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
      </div>
      <h1 class="text-4xl font-bold tracking-tight text-surface-900 sm:text-5xl">Instagram Content Moderation</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-surface-500">
        Keep your Instagram profile safe from toxic comments. AI-powered moderation in minutes, no code needed.
      </p>
      <div class="mt-8 flex items-center justify-center gap-4">
        <a href="https://app.openmoderation.com/signup" class="inline-flex items-center gap-2 rounded-lg bg-brand-900 px-6 py-3 text-sm font-medium text-white shadow-sm hover:bg-brand-800">Try it for free</a>
        <a href="/how-it-works" class="inline-flex items-center gap-2 rounded-lg border border-surface-300 px-6 py-3 text-sm font-medium text-surface-700 hover:border-surface-900">How it works</a>
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">Moderation that's simple to use</h2>
        <p class="mt-4 text-lg text-surface-500">Three steps to a safer Instagram profile.</p>
      </div>
      <div class="grid gap-8 md:grid-cols-3">
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-8 text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-brand-100 text-brand-600">
            <span class="text-xl font-bold">1</span>
          </div>
          <h3 class="text-lg font-semibold text-surface-900">Sign up</h3>
          <p class="mt-2 text-sm text-surface-500">Create a free OpenModeration account. Cloud or self-hosted — choose what works for you.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-8 text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-brand-100 text-brand-600">
            <span class="text-xl font-bold">2</span>
          </div>
          <h3 class="text-lg font-semibold text-surface-900">Connect Instagram</h3>
          <p class="mt-2 text-sm text-surface-500">Link your Instagram account to the platform in just a few clicks. Use your own credentials securely.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-8 text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-brand-100 text-brand-600">
            <span class="text-xl font-bold">3</span>
          </div>
          <h3 class="text-lg font-semibold text-surface-900">Go live in minutes</h3>
          <p class="mt-2 text-sm text-surface-500">Set your moderation rules and let AI protect your profile. Hide, delete, or flag content automatically.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-surface-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">Detection that goes beyond keywords</h2>
        <p class="mt-4 text-lg text-surface-500">Context-aware AI understands nuance, sarcasm, and intent.</p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">Toxicity</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">Hate speech</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">Harassment</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">Spam</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">NSFW</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">Scams & phishing</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">PII</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">Self-harm</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">Profanity</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">Sentiment</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">Sensitive topics</span></div>
        <div class="rounded-xl border border-surface-200 bg-white p-4 text-center"><span class="text-sm font-medium text-surface-900">URL risks</span></div>
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">Why it's the simplest Instagram moderation tool</h2>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <h3 class="font-semibold text-surface-900">Minute setup, zero code</h3>
          <p class="mt-2 text-sm text-surface-500">Connect your Instagram account from the dashboard. No API knowledge needed. No developer required.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <h3 class="font-semibold text-surface-900">Context-aware AI</h3>
          <p class="mt-2 text-sm text-surface-500">Understands conversation context. The same sentence is evaluated differently based on what came before — just like a human moderator.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <h3 class="font-semibold text-surface-900">Automatic enforcement</h3>
          <p class="mt-2 text-sm text-surface-500">Hide or delete violating comments automatically. Your Instagram profile stays clean without lifting a finger.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <h3 class="font-semibold text-surface-900">120+ languages</h3>
          <p class="mt-2 text-sm text-surface-500">Your global audience speaks many languages. One platform moderates all of them with equal accuracy.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <h3 class="font-semibold text-surface-900">Custom rules in plain English</h3>
          <p class="mt-2 text-sm text-surface-500">Write rules the way you'd explain them to a person. Our AI understands your policy and applies it consistently.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <h3 class="font-semibold text-surface-900">Open source & private</h3>
          <p class="mt-2 text-sm text-surface-500">Self-host on your own infrastructure. All data stays yours. AGPL v3 — transparent and auditable.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-surface-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <FAQ items={faqItems} title="Frequently asked questions about Instagram moderation" />
    </div>
  </section>

  <CTASection />
</BaseLayout>
