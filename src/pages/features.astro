---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import CodeBlock from '../components/CodeBlock.astro';

const curlExample = `# Works the same way with every provider
curl -X POST https://api.openmoderation.com/v1/moderation \\
  -H "Authorization: Bearer om_key_..." \\
  -H "Content-Type: application/json" \\
  -d '{
    "input": "Your text to moderate here",
    "model": "openai/omni-moderation-latest",
    "language": "en"
  }'

# Response (same format, every time)
{
  "id": "modr_01JXK...",
  "model": "openai/omni-moderation-latest",
  "results": [{
    "category": "hate",
    "score": 0.02,
    "flagged": false
  }],
  "flagged": false,
  "usage": {
    "latency_ms": 243,
    "provider": "openai"
  }
}`;

const featureCategories = [
  {
    title: 'Single Integration',
    description: 'One API endpoint that works the same no matter which provider you choose. Consistent results, no extra code.',
    items: [
      { title: 'One connection to all moderation providers', desc: 'Submit content once, get back a clear pass/fail verdict and category scores &mdash; whether you use OpenAI, Azure, or an LLM.' },
      { title: 'Pre-built content categories', desc: 'Ready-made categories covering hate, harassment, sexual content, violence, self-harm, spam, misinformation, PII, and more.' },
      { title: 'Automatic Provider Selection', desc: 'Tell us your language, content type, and budget. We route each request to the best provider automatically.' },
      { title: 'Smarter Moderation Decisions', desc: 'Factor in conversation context, author history, channel type, and your own policies for more accurate decisions.' },
      { title: 'Bulk Content Review', desc: 'Submit up to 10,000 items at once for async processing. Get results pushed to your system when ready.' },
      { title: 'Custom Moderation Policies', desc: 'Define your own categories using any LLM. Provide examples and let the model classify content your way.' },
    ],
  },
  {
    title: 'Moderation Dashboard',
    description: 'Full web interface to manage your content moderation operations.',
    items: [
      { title: 'Access Management', desc: 'Create and manage access keys. Set usage limits per key and configure provider credentials.' },
      { title: 'Team & Role Management', desc: 'Easily manage your human moderators, assign roles, and set permissions without relying on your IT department.' },
      { title: 'Report Management', desc: 'A centralized queue to process user reports, track resolution status, and ensure no flagged content falls through the cracks.' },
      { title: 'Activity History', desc: 'Every moderation request logged with its verdict, provider, response time, and category scores.' },
      { title: 'Provider Health Monitoring', desc: 'See the real-time status of all your providers: uptime, response times, and error rates.' },
      { title: 'Performance Reports', desc: 'Track moderation volume, flag rates, compare provider performance, and review cost trends.' },
      { title: 'Connector Management', desc: 'Connect your social platform accounts with your own credentials.' },
      { title: 'Rule Configuration', desc: 'Define forbidden words, set category thresholds, and write your community charter — three simple tools, no code required.' },
    ],
  },
  {
    title: 'Automated Moderation',
    description: 'Define your moderation rules with three simple tools: forbidden words, category thresholds, and your community charter in plain language.',
    items: [
      { title: 'Context-Aware AI Rules', desc: 'Combine AI confidence scores with your community guidelines. Move beyond fragile, rigid keyword logic.' },
      { title: 'Auto-Actions', desc: 'When a threshold is breached, the Action Engine steps in — hide, delete, flag, notify, or mark as spam.' },
      { title: 'Human-in-the-Loop', desc: 'Seamlessly route nuanced or borderline cases to your human moderators for final, informed decisions.' },
      { title: 'Manual Review Queue', desc: 'Flagged content goes to a queue for human moderators to approve or reject.' },
      { title: 'Webhook Notifications', desc: 'Get real-time alerts for flagged content, batch completion, provider errors, and more.' },
      { title: 'Full Audit Trail', desc: 'Every action is logged: which rule triggered, what action was taken, and the outcome.' },
    ],
  },
  {
    title: 'Platform Integrations',
    description: 'Connect directly to social platforms to automatically ingest and moderate content.',
    items: [
      { title: 'Facebook', desc: 'Receive comments and posts. Automatically hide or remove content that breaks your rules.' },
      { title: 'Instagram', desc: 'Moderate Instagram comments and messages. Keep your profile safe from toxic or spammy content.' },
      { title: 'YouTube', desc: 'Ingest video comments. Mark as spam or send to your review queue.' },
      { title: 'Use Your Own Platform Access', desc: 'Bring your own platform tokens. We never store them in plaintext.' },
      { title: 'Generic Webhook Receiver', desc: 'Ingest content from any platform that supports outgoing webhooks.' },
      { title: 'Generic Webhook Callback', desc: 'Send moderation results to your own webhook for custom integrations.' },
    ],
  },
];
---

<BaseLayout title="Features &mdash; Open-Source Moderation Platform" description="Explore all features of OpenModeration: unified API, admin dashboard, action engine, native connectors, BYOK, batch processing, and DSA-compliant audit trails.">
  <section class="bg-gradient-to-b from-brand-50 to-white py-20">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold tracking-tight text-surface-900 sm:text-5xl">Features</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-surface-500">
        A complete moderation platform. Not just an API &mdash; a full pipeline from ingestion to action.
      </p>
    </div>
  </section>

  {featureCategories.map((cat) => (
    <section class="scroll-mt-16 border-t border-surface-100 bg-white py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto mb-12 max-w-2xl text-center">
          <h2 class="text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">{cat.title}</h2>
          <p class="mt-4 text-lg text-surface-500">{cat.description}</p>
        </div>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {cat.items.map((item) => (
            <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
              <h3 class="font-semibold text-surface-900">{item.title}</h3>
              <p class="mt-2 text-sm text-surface-500">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- API Reference Snippet -->
  <section class="border-t border-surface-100 bg-surface-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <h2 class="text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">Simple, predictable, reliable</h2>
          <p class="mt-4 text-lg text-surface-500">
            Consistent results across every provider. One format, one integration.
          </p>
          <div class="mt-6 space-y-4">
            <div class="flex items-start gap-3">
              <svg class="mt-1 h-5 w-5 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <p class="text-sm text-surface-600"><strong>Same format</strong> for OpenAI, Azure, HuggingFace, Mistral, or any LLM &mdash; no extra code to write.</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="mt-1 h-5 w-5 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <p class="text-sm text-surface-600"><strong>Secure access keys</strong> with scoped permissions and usage limits per key.</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="mt-1 h-5 w-5 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <p class="text-sm text-surface-600"><strong>Interactive API docs</strong> auto-generated. Try requests directly from your browser.</p>
            </div>
          </div>
        </div>
        <div>
          <CodeBlock code={curlExample} lang="bash" />
        </div>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>