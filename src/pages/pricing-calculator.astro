---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import FAQ from '../components/FAQ.astro';

const calculatorJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Moderation Cost Calculator",
  "description": "Estimate your moderation costs with OpenModeration. Compare self-hosted, cloud, and build-your-own pricing."
};

const faqItems = [
  {
    question: "What affects the total cost of self-hosted OpenModeration?",
    answer: "The main cost drivers are: (1) AI provider API fees &mdash; paid per-request to OpenAI, Azure, or Anthropic based on your volume; (2) Infrastructure &mdash; a small VPS starts at ~$10/mo, scaling up with traffic; (3) Optional managed database services. The OpenModeration software itself is free."
  },
  {
    question: "How does your SaaS pricing compare to other platforms?",
    answer: "Our cloud plan starts at $49/mo with all features included. Most proprietary platforms charge per-seat or per-request on top of a base fee, leading to unpredictable bills. With OpenModeration, you only pay the platform fee plus the AI provider usage &mdash; no hidden per-moderator or per-action costs."
  },
  {
    question: "Do I need to commit to an annual contract?",
    answer: "No. Both self-hosted (free) and cloud (monthly) plans are month-to-month. Enterprise customers can opt for annual billing at a discount, but it's never required. No sales calls, no lock-in."
  },
  {
    question: "What if my volume exceeds 1 million requests per month?",
    answer: "Self-hosted scales linearly &mdash; your main cost increase is AI provider API fees and infrastructure. For cloud, we offer custom enterprise pricing at high volumes. Contact us for a tailored quote."
  },
  {
    question: "Can I migrate from self-hosted to cloud without downtime?",
    answer: "Yes. OpenModeration uses the same data format and schema regardless of deployment mode. You can export your configuration and rules from self-hosted and import them into the cloud plan. We provide migration scripts and can assist with the transition."
  },
  {
    question: "How do 'build your own' costs compare long-term?",
    answer: "Building in-house requires 1&ndash;3 engineers working for 3&ndash;6 months minimum ($60K&ndash;$150K upfront), plus ongoing maintenance, provider integration updates, and infrastructure costs. OpenModeration gives you the same result in an afternoon for zero software cost."
  }
];
---

<BaseLayout title="Moderation Cost Calculator - OpenModeration" description="Estimate your moderation costs with OpenModeration. Compare self-hosted, cloud, and build-your-own pricing." jsonLd={calculatorJsonLd}>
  <section class="bg-gradient-to-b from-brand-50 to-white py-20">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold tracking-tight text-surface-900 sm:text-5xl">Moderation Cost Calculator</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-surface-500">
        See how much your team could save with OpenModeration. Compare self-hosted, managed cloud, and building in-house across three real-world scenarios.
      </p>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-3">
        <div class="rounded-2xl border border-surface-200 bg-surface-50 p-6 shadow-sm">
          <h3 class="text-lg font-semibold text-surface-900">Small Platform</h3>
          <p class="text-sm text-surface-500">10K requests / month</p>
          <div class="mt-6 space-y-4">
            <div class="rounded-lg border border-surface-200 bg-white p-4">
              <div class="flex items-center justify-between">
                <span class="text-sm font-medium text-surface-900">Self-hosted</span>
                <span class="text-xs font-semibold text-accent-600">Best value</span>
              </div>
              <p class="mt-1 text-2xl font-bold text-surface-900">~$25/mo</p>
              <p class="text-xs text-surface-400">Software free + ~$10 AI + ~$15 infra</p>
            </div>
            <div class="rounded-lg border border-surface-200 bg-white p-4">
              <div class="flex items-center justify-between">
                <span class="text-sm font-medium text-surface-900">Cloud SaaS</span>
                <span class="text-xs font-semibold text-surface-500">Managed</span>
              </div>
              <p class="mt-1 text-2xl font-bold text-surface-900">~$49/mo</p>
              <p class="text-xs text-surface-400">All features, zero infra management</p>
            </div>
            <div class="rounded-lg border border-surface-200 bg-white p-4">
              <div class="flex items-center justify-between">
                <span class="text-sm font-medium text-surface-900">Build In-House</span>
                <span class="text-xs font-semibold text-amber-600">Most expensive</span>
              </div>
              <p class="mt-1 text-2xl font-bold text-surface-900">~$8K/mo</p>
              <p class="text-xs text-surface-400">Amortized dev cost over 12 months</p>
            </div>
          </div>
        </div>

        <div class="relative rounded-2xl border-2 border-brand-500 bg-white p-6 shadow-md">
          <div class="absolute -top-3 left-6 rounded-full bg-brand-600 px-4 py-1 text-xs font-semibold text-white">Popular</div>
          <h3 class="text-lg font-semibold text-surface-900">Growing Platform</h3>
          <p class="text-sm text-surface-500">100K requests / month</p>
          <div class="mt-6 space-y-4">
            <div class="rounded-lg border border-brand-100 bg-brand-50 p-4">
              <div class="flex items-center justify-between">
                <span class="text-sm font-medium text-surface-900">Self-hosted</span>
                <span class="text-xs font-semibold text-accent-600">Best value</span>
              </div>
              <p class="mt-1 text-2xl font-bold text-surface-900">~$100/mo</p>
              <p class="text-xs text-surface-400">Software free + ~$75 AI + ~$25 infra</p>
            </div>
            <div class="rounded-lg border border-surface-200 bg-white p-4">
              <div class="flex items-center justify-between">
                <span class="text-sm font-medium text-surface-900">Cloud SaaS</span>
                <span class="text-xs font-semibold text-surface-500">Managed</span>
              </div>
              <p class="mt-1 text-2xl font-bold text-surface-900">~$149/mo</p>
              <p class="text-xs text-surface-400">$49 platform + ~$100 AI usage</p>
            </div>
            <div class="rounded-lg border border-surface-200 bg-white p-4">
              <div class="flex items-center justify-between">
                <span class="text-sm font-medium text-surface-900">Build In-House</span>
                <span class="text-xs font-semibold text-amber-600">Most expensive</span>
              </div>
              <p class="mt-1 text-2xl font-bold text-surface-900">~$16K/mo</p>
              <p class="text-xs text-surface-400">Amortized dev + ongoing maintenance</p>
            </div>
          </div>
        </div>

        <div class="rounded-2xl border border-surface-200 bg-surface-50 p-6 shadow-sm">
          <h3 class="text-lg font-semibold text-surface-900">Large Platform</h3>
          <p class="text-sm text-surface-500">1M requests / month</p>
          <div class="mt-6 space-y-4">
            <div class="rounded-lg border border-surface-200 bg-white p-4">
              <div class="flex items-center justify-between">
                <span class="text-sm font-medium text-surface-900">Self-hosted</span>
                <span class="text-xs font-semibold text-accent-600">Best value</span>
              </div>
              <p class="mt-1 text-2xl font-bold text-surface-900">~$1K/mo</p>
              <p class="text-xs text-surface-400">Software free + ~$750 AI + ~$250 infra</p>
            </div>
            <div class="rounded-lg border border-surface-200 bg-white p-4">
              <div class="flex items-center justify-between">
                <span class="text-sm font-medium text-surface-900">Cloud SaaS</span>
                <span class="text-xs font-semibold text-brand-600">Custom</span>
              </div>
              <p class="mt-1 text-2xl font-bold text-surface-900">Custom</p>
              <p class="text-xs text-surface-400">Enterprise pricing with volume discounts</p>
            </div>
            <div class="rounded-lg border border-surface-200 bg-white p-4">
              <div class="flex items-center justify-between">
                <span class="text-sm font-medium text-surface-900">Build In-House</span>
                <span class="text-xs font-semibold text-amber-600">Most expensive</span>
              </div>
              <p class="mt-1 text-2xl font-bold text-surface-900">~$50K/mo</p>
              <p class="text-xs text-surface-400">Full team + infrastructure at scale</p>
            </div>
          </div>
        </div>
      </div>

      <p class="mt-8 text-center text-sm text-surface-400">
        Estimates include AI provider fees and infrastructure. Build in-house costs are amortized over 12 months. Actual costs may vary.
      </p>
    </div>
  </section>

  <section class="bg-surface-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-center text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">What's included with OpenModeration</h2>
      <p class="mx-auto mt-4 max-w-2xl text-center text-lg text-surface-500">Every plan gives you the full platform, no feature gating.</p>
      <div class="mx-auto mt-12 grid max-w-5xl gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-xl border border-surface-200 bg-white p-6">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100">
            <svg class="h-5 w-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h3 class="mt-4 text-base font-semibold text-surface-900">4 AI Provider Integrations</h3>
          <p class="mt-2 text-sm text-surface-500">OpenAI, Azure, Anthropic, and Amazon Bedrock &mdash; switch between them with a config change.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-white p-6">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100">
            <svg class="h-5 w-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="mt-4 text-base font-semibold text-surface-900">Action Engine & Rules</h3>
          <p class="mt-2 text-sm text-surface-500">Conditional moderation actions &mdash; auto-flag, block, escalate, or notify based on confidence scores and content type.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-white p-6">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100">
            <svg class="h-5 w-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
          </div>
          <h3 class="mt-4 text-base font-semibold text-surface-900">Native Connectors</h3>
          <p class="mt-2 text-sm text-surface-500">Pre-built integrations for Facebook, YouTube, Discord, and more. Connect your platforms in minutes.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-white p-6">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100">
            <svg class="h-5 w-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"/></svg>
          </div>
          <h3 class="mt-4 text-base font-semibold text-surface-900">Admin Dashboard</h3>
          <p class="mt-2 text-sm text-surface-500">Real-time moderation queue, analytics, action logs, and rule management &mdash; all in one UI.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-white p-6">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100">
            <svg class="h-5 w-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
          </div>
          <h3 class="mt-4 text-base font-semibold text-surface-900">BYOK</h3>
          <p class="mt-2 text-sm text-surface-500">Bring your own API keys for all AI providers. No data leaves your account. Full control over provider choice and cost.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-white p-6">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100">
            <svg class="h-5 w-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>
          </div>
          <h3 class="mt-4 text-base font-semibold text-surface-900">Docker Deployment</h3>
          <p class="mt-2 text-sm text-surface-500">One-command deploy with Docker Compose. PostgreSQL, Redis, and the app stack &mdash; all containerized and ready.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-center text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">Frequently asked questions</h2>
      <p class="mx-auto mt-4 max-w-2xl text-center text-lg text-surface-500">Everything you need to know about pricing, scaling, and switching.</p>
      <div class="mt-12">
        <FAQ items={faqItems} />
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>