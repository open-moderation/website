---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';

const pricingJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "OpenModeration",
  "description": "Open-source moderation platform with self-hosted, BYOK SaaS, and managed cloud plans.",
  "offers": [
    { "@type": "Offer", "name": "Self-Hosted", "price": "0", "priceCurrency": "EUR", "availability": "https://schema.org/InStock" },
    { "@type": "Offer", "name": "BYOK SaaS", "price": "49", "priceCurrency": "EUR", "availability": "https://schema.org/InStock" },
    { "@type": "Offer", "name": "Managed SaaS", "price": "199", "priceCurrency": "EUR", "availability": "https://schema.org/InStock" }
  ]
};
---

<BaseLayout title="Pricing &mdash; OpenModeration" description="Start free with self-hosted, use your own provider keys, or let us manage everything. Transparent pricing from &euro;49/mo." jsonLd={pricingJsonLd}>
  <section class="bg-gradient-to-b from-brand-50 to-white py-20">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-surface-200 bg-white px-4 py-1.5 text-sm text-surface-600 shadow-sm">
        <span class="flex items-center gap-1.5">
          &#x1F1EA;&#x1F1FA;
          Made and hosted in the EU
        </span>
      </div>
      <h1 class="text-4xl font-bold tracking-tight text-surface-900 sm:text-5xl">Simple, transparent pricing</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-surface-500">
        Self-host for free, bring your own keys, or let us manage everything.
        No sales calls. No hidden fees.
      </p>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto grid max-w-5xl grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
        <!-- Self-Hosted -->
        <div class="rounded-2xl border border-surface-200 bg-surface-50 p-6 shadow-sm">
          <div class="flex items-center justify-between">
            <div>
              <h2 class="text-lg font-bold text-surface-900">Self-Hosted</h2>
              <p class="mt-1 text-xs text-surface-500">Open source</p>
            </div>
            <span class="rounded-full bg-accent-100 px-2.5 py-0.5 text-xs font-semibold text-accent-700">Free</span>
          </div>
          <p class="mt-4 text-3xl font-bold text-surface-900">&euro;0</p>
          <p class="mt-1 text-xs text-surface-500">Unlimited, no restrictions</p>
          <ul class="mt-6 space-y-2 text-sm text-surface-600">
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> All features included</li>
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Bring your own keys</li>
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Docker deploy</li>
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Community support</li>
          </ul>
          <a href="https://github.com/open-moderation/OpenModeration" class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-lg border border-surface-300 px-4 py-2.5 text-sm font-semibold text-surface-700 transition hover:bg-surface-50">
            Deploy self-hosted
          </a>
        </div>

        <!-- BYOK SaaS -->
        <div class="relative rounded-2xl border-2 border-brand-500 bg-white p-6 shadow-md lg:col-span-1">
          <div class="absolute -top-3 right-4 rounded-full bg-brand-600 px-2.5 py-0.5 text-[10px] font-semibold text-white">Popular</div>
          <div class="flex items-center justify-between">
            <div>
              <h2 class="text-lg font-bold text-surface-900">BYOK</h2>
              <p class="mt-1 text-xs text-surface-500">Your keys, hosted</p>
            </div>
          </div>
          <p class="mt-4">
            <span class="text-3xl font-bold text-surface-900">&euro;49</span>
            <span class="text-sm text-surface-400">/mo</span>
          </p>
          <p class="mt-1 text-xs text-surface-500">You pay providers directly</p>
          <ul class="mt-6 space-y-2 text-sm text-surface-600">
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Managed hosting</li>
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> 100K requests/mo included</li>
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> EU-hosted infrastructure</li>
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Standard support</li>
          </ul>
          <a href="https://app.openmoderation.com" class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-lg bg-brand-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-700">
            Start free trial
          </a>
        </div>

        <!-- Managed SaaS -->
        <div class="rounded-2xl border border-surface-200 bg-surface-50 p-6 shadow-sm lg:col-span-1">
          <div class="flex items-center justify-between">
            <div>
              <h2 class="text-lg font-bold text-surface-900">Managed</h2>
              <p class="mt-1 text-xs text-surface-500">Fully managed</p>
            </div>
            <span class="rounded-full bg-brand-100 px-2.5 py-0.5 text-xs font-semibold text-brand-700">Coming soon</span>
          </div>
          <p class="mt-4">
            <span class="text-3xl font-bold text-surface-900">&euro;199</span>
            <span class="text-sm text-surface-400">/mo</span>
          </p>
          <p class="mt-1 text-xs text-surface-500">Keys & hosting included</p>
          <ul class="mt-6 space-y-2 text-sm text-surface-600">
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Platform-managed provider keys</li>
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> 250K requests/mo included</li>
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Priority support & SLA</li>
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Team management & analytics</li>
          </ul>
          <a href="https://app.openmoderation.com" class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-lg border border-surface-300 px-4 py-2.5 text-sm font-semibold text-surface-700 transition hover:bg-surface-50">
            Join the waitlist
          </a>
        </div>

        <!-- Enterprise -->
        <div class="rounded-2xl border border-surface-200 bg-ink-900 p-6 text-white shadow-sm lg:col-span-1">
          <h2 class="text-lg font-bold">Enterprise</h2>
          <p class="mt-1 text-xs text-surface-400">Custom</p>
          <p class="mt-4 text-3xl font-bold">Custom</p>
          <ul class="mt-6 space-y-2 text-sm text-surface-300">
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-turquoise" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Dedicated infrastructure</li>
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-turquoise" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Custom SLA & SOC 2</li>
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-turquoise" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Unlimited requests</li>
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-turquoise" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Dedicated support engineer</li>
          </ul>
          <a href="/about" class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-lg bg-white px-4 py-2.5 text-sm font-semibold text-surface-900 shadow-sm transition hover:bg-surface-100">
            Contact us
          </a>
        </div>
      </div>

      <!-- EU badge -->
      <div class="mx-auto mt-12 max-w-lg rounded-xl border border-surface-200 bg-surface-50 p-5 text-center">
        <div class="mb-2 inline-flex items-center gap-2 rounded-full bg-surface-100 px-3 py-1 text-xs font-medium text-surface-600">
          <span class="flex items-center gap-1.5">
            &#x1F1EA;&#x1F1FA;
            Made and hosted in the EU
          </span>
        </div>
        <p class="text-sm text-surface-500">All SaaS plans run on European-owned infrastructure. Your data never leaves the EU. Fully GDPR-compliant.</p>
      </div>
    </div>
  </section>

  <!-- BYOK vs Managed comparison -->
  <section class="bg-surface-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">Two SaaS modes, one platform</h2>
        <p class="mt-4 text-lg text-surface-500">
          Choose how much you want to manage yourself.
        </p>
      </div>
      <div class="overflow-hidden rounded-xl border border-surface-200">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="bg-surface-100">
              <th class="px-6 py-4 font-semibold text-surface-900"></th>
              <th class="px-6 py-4 font-semibold text-brand-600">BYOK &mdash; &euro;49/mo</th>
              <th class="px-6 py-4 font-semibold text-brand-600">Managed &mdash; &euro;199/mo</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-surface-200 bg-white">
            <tr><td class="px-6 py-4 font-medium text-surface-900">Provider keys</td><td class="px-6 py-4 text-surface-600">You bring your own (OpenAI, Azure, etc.)</td><td class="px-6 py-4 text-surface-600">We provide and manage them</td></tr>
            <tr><td class="px-6 py-4 font-medium text-surface-900">Provider costs</td><td class="px-6 py-4 text-surface-600">You pay providers directly</td><td class="px-6 py-4 text-surface-600">Included in subscription (250K req)</td></tr>
            <tr><td class="px-6 py-4 font-medium text-surface-900">Provider relationships</td><td class="px-6 py-4 text-surface-600">You keep direct contracts and volume pricing</td><td class="px-6 py-4 text-surface-600">We handle them &mdash; no setup needed</td></tr>
            <tr><td class="px-6 py-4 font-medium text-surface-900">EU hosting</td><td class="px-6 py-4 text-surface-600">Yes &mdash; European infrastructure</td><td class="px-6 py-4 text-surface-600">Yes &mdash; European infrastructure</td></tr>
            <tr><td class="px-6 py-4 font-medium text-surface-900">Request volume</td><td class="px-6 py-4 text-surface-600">100K/mo included</td><td class="px-6 py-4 text-surface-600">250K/mo included</td></tr>
            <tr><td class="px-6 py-4 font-medium text-surface-900">Support</td><td class="px-6 py-4 text-surface-600">Standard</td><td class="px-6 py-4 text-surface-600">Priority + SLA</td></tr>
            <tr><td class="px-6 py-4 font-medium text-surface-900">Best for</td><td class="px-6 py-4 text-surface-600">Teams that already have provider accounts</td><td class="px-6 py-4 text-surface-600">Teams that want zero setup, all-in-one</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Cost example -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">Real cost example</h2>
        <p class="mt-4 text-lg text-surface-500">
          100,000 moderation requests per month.
        </p>
      </div>
      <div class="mt-8 grid gap-6 md:grid-cols-3">
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6 text-center">
          <p class="text-sm font-medium text-surface-500">Self-hosted + BYOK</p>
          <p class="mt-2 text-3xl font-bold text-surface-900">~&euro;25<span class="text-base font-normal text-surface-400">/mo</span></p>
          <ul class="mt-4 space-y-1 text-xs text-surface-500">
            <li>OpenModeration: &euro;0</li>
            <li>OpenAI provider: ~&euro;10</li>
            <li>Infrastructure: ~&euro;15</li>
          </ul>
        </div>
        <div class="rounded-xl border-2 border-brand-500 bg-brand-50 p-6 text-center">
          <p class="text-sm font-medium text-brand-700">BYOK SaaS</p>
          <p class="mt-2 text-3xl font-bold text-surface-900">&euro;59<span class="text-base font-normal text-surface-400">/mo</span></p>
          <ul class="mt-4 space-y-1 text-xs text-surface-500">
            <li>Subscription: &euro;49</li>
            <li>OpenAI provider: ~&euro;10</li>
            <li>Zero infra to manage</li>
          </ul>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6 text-center">
          <p class="text-sm font-medium text-surface-500">Managed SaaS</p>
          <p class="mt-2 text-3xl font-bold text-surface-900">&euro;199<span class="text-base font-normal text-surface-400">/mo</span></p>
          <ul class="mt-4 space-y-1 text-xs text-surface-500">
            <li>All inclusive</li>
            <li>250K requests</li>
            <li>Priority support</li>
          </ul>
        </div>
      </div>
      <p class="mt-6 text-center text-xs text-surface-400">Provider costs based on OpenAI Moderation API pricing at $0.0001/1K tokens. Approximate &euro;.</p>
    </div>
  </section>

  <CTASection />
</BaseLayout>