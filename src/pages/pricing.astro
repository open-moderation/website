---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';

const pricingJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "OpenModeration",
  "description": "Open-source moderation platform with free cloud tier, Pro plan at €99/mo, and enterprise plans. Also available as free self-hosted.",
  "offers": [
    { "@type": "Offer", "name": "Free", "price": "0", "priceCurrency": "EUR", "availability": "https://schema.org/InStock" },
    { "@type": "Offer", "name": "Pro", "price": "99", "priceCurrency": "EUR", "availability": "https://schema.org/InStock" },
    { "@type": "Offer", "name": "Enterprise", "priceCurrency": "EUR", "availability": "https://schema.org/InStock" }
  ]
};
---

<BaseLayout title="Pricing &mdash; OpenModeration" description="Start free with 1,000 req/mo, go Pro at &euro;99/mo for 10K req, or self-host for free. Transparent pricing, no hidden fees." jsonLd={pricingJsonLd}>
  <section class="bg-gradient-to-b from-brand-50 to-white py-20">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-surface-200 bg-white px-4 py-1.5 text-sm text-surface-600 shadow-sm">
        <span class="flex items-center gap-1.5">
          &#x1F1EA;&#x1F1FA;
          Made and hosted in the EU
        </span>
      </div>
      <h1 class="text-4xl font-bold tracking-tight text-surface-900 sm:text-5xl">Simple, transparent pricing</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-surface-500">
        Start free with 1,000 requests per month, or go Pro for the full managed experience.
        No sales calls. No hidden fees.
      </p>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto grid max-w-5xl grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <!-- Free -->
        <div class="rounded-2xl border border-surface-200 bg-white p-6 shadow-sm">
          <div class="flex items-center justify-between">
            <div>
              <h2 class="text-lg font-bold text-surface-900">Free</h2>
              <p class="mt-1 text-xs text-surface-500">Managed cloud</p>
            </div>
            <span class="rounded-full bg-accent-100 px-2.5 py-0.5 text-xs font-semibold text-accent-700">Free</span>
          </div>
          <p class="mt-4 text-3xl font-bold text-surface-900">&euro;0</p>
          <p class="mt-1 text-xs text-surface-500">Up to 1,000 requests / month</p>
          <ul class="mt-6 space-y-2 text-sm text-surface-600">
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> All features included</li>
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Bring your own keys</li>
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> EU-hosted infrastructure</li>
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Community support</li>
          </ul>
          <a href="https://app.openmoderation.com/signup" class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-lg border border-surface-300 px-4 py-2.5 text-sm font-semibold text-surface-700 transition hover:bg-surface-50">
            Start free
          </a>
        </div>

        <!-- Pro -->
        <div class="relative rounded-2xl border-2 border-brand-500 bg-white p-6 shadow-md lg:col-span-1">
          <div class="absolute -top-3 right-4 rounded-full bg-brand-600 px-2.5 py-0.5 text-[10px] font-semibold text-white">Popular</div>
          <div class="flex items-center justify-between">
            <div>
              <h2 class="text-lg font-bold text-surface-900">Pro</h2>
              <p class="mt-1 text-xs text-surface-500">Fully managed cloud</p>
            </div>
          </div>
          <p class="mt-4">
            <span class="text-3xl font-bold text-surface-900">&euro;99</span>
            <span class="text-sm text-surface-400">/mo</span>
          </p>
          <p class="mt-1">
            <span class="text-sm text-surface-400">&euro;990</span>
            <span class="text-sm text-surface-400">/year &mdash; save ~17%</span>
          </p>
          <ul class="mt-6 space-y-2 text-sm text-surface-600">
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Managed hosting & infrastructure</li>
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> 10K requests/mo included</li>
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> EU-hosted infrastructure</li>
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Platform-managed provider keys</li>
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Priority support & SLA</li>
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Team management & analytics</li>
          </ul>
          <a href="https://app.openmoderation.com/signup" class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-lg bg-brand-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-700">
            Try Pro
          </a>
        </div>

        <!-- Enterprise -->
        <div class="rounded-2xl border border-surface-200 bg-ink-900 p-6 text-white shadow-sm lg:col-span-1">
          <h2 class="text-lg font-bold">Enterprise</h2>
          <p class="mt-1 text-xs text-surface-400">Custom</p>
          <p class="mt-4 text-3xl font-bold">Custom</p>
          <ul class="mt-6 space-y-2 text-sm text-surface-300">
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-turquoise" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Dedicated infrastructure</li>
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-turquoise" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Custom SLA & SOC 2</li>
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-turquoise" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Unlimited requests</li>
            <li class="flex items-center gap-2"><svg class="h-4 w-4 shrink-0 text-turquoise" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Dedicated support engineer</li>
          </ul>
          <a href="mailto:contact@openmoderation.com" class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-lg bg-white px-4 py-2.5 text-sm font-semibold text-surface-900 shadow-sm transition hover:bg-surface-100">
            Contact us
          </a>
        </div>
      </div>

      <!-- Self-hosted banner -->
      <div class="mx-auto mt-12 max-w-3xl rounded-xl border border-surface-200 bg-surface-50 p-6">
        <div class="flex items-start gap-4">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand-100 text-brand-600">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
          </div>
          <div class="flex-1">
            <h3 class="text-base font-semibold text-surface-900">Prefer to self-host?</h3>
            <p class="mt-2 text-sm text-surface-500">
              Deploy OpenModeration on your own infrastructure for free. All features, unlimited usage, full data sovereignty.
              Open source under AGPL v3. Deploys in minutes with Docker.
            </p>
            <p class="mt-2 text-sm">
              <code class="rounded bg-surface-200 px-2 py-0.5 font-mono text-xs text-surface-700">docker compose up</code>
            </p>
            <a href="https://github.com/open-moderation/open-moderation" class="mt-3 inline-flex items-center gap-2 text-sm font-medium text-brand-600 transition hover:text-brand-500">
              Deploy self-hosted
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>

      <!-- EU badge -->
      <div class="mx-auto mt-8 max-w-lg rounded-xl border border-surface-200 bg-surface-50 p-5 text-center">
        <div class="mb-2 inline-flex items-center gap-2 rounded-full bg-surface-100 px-3 py-1 text-xs font-medium text-surface-600">
          <span class="flex items-center gap-1.5">
            &#x1F1EA;&#x1F1FA;
            Made and hosted in the EU
          </span>
        </div>
        <p class="text-sm text-surface-500">All SaaS plans run on European-owned infrastructure. Your data never leaves the EU. Fully GDPR-compliant.</p>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
