---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
---

<BaseLayout title="Moderation Console &mdash; OpenModeration" description="Full visibility into your moderation operations &mdash; manage access, review decisions, monitor service health, and track performance.">
  <section class="bg-gradient-to-b from-brand-50 to-white py-20">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold tracking-tight text-surface-900 sm:text-5xl">Moderation Console</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-surface-500">
        Full visibility and control over your moderation infrastructure.
      </p>
    </div>
  </section>

  <!-- Dashboard Preview -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-16 grid gap-4 grid-cols-2 md:grid-cols-4">
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <p class="text-sm text-surface-500">Requests today</p>
          <p class="mt-1 text-3xl font-bold text-surface-900">84.2K</p>
          <p class="mt-1 text-xs text-accent-600">+12% vs yesterday</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <p class="text-sm text-surface-500">Flagged rate</p>
          <p class="mt-1 text-3xl font-bold text-surface-900">4.7%</p>
          <p class="mt-1 text-xs text-surface-500">3,957 flagged items</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <p class="text-sm text-surface-500">Avg latency</p>
          <p class="mt-1 text-3xl font-bold text-surface-900">267ms</p>
          <p class="mt-1 text-xs text-accent-600">P99: 890ms</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <p class="text-sm text-surface-500">Active providers</p>
          <p class="mt-1 text-3xl font-bold text-surface-900">4/4</p>
          <p class="mt-1 text-xs text-surface-500">All operational</p>
        </div>
      </div>

      <div class="grid gap-8 lg:grid-cols-2">
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <h3 class="mb-4 font-semibold text-surface-900">Usage over time</h3>
          <div class="flex items-end gap-2" style="height: 160px;">
            <div class="flex-1 rounded-t bg-brand-200" style="height: 60%"></div>
            <div class="flex-1 rounded-t bg-brand-200" style="height: 45%"></div>
            <div class="flex-1 rounded-t bg-brand-200" style="height: 75%"></div>
            <div class="flex-1 rounded-t bg-brand-200" style="height: 55%"></div>
            <div class="flex-1 rounded-t bg-brand-200" style="height: 80%"></div>
            <div class="flex-1 rounded-t bg-brand-300" style="height: 70%"></div>
            <div class="flex-1 rounded-t bg-brand-400" style="height: 90%"></div>
            <div class="flex-1 rounded-t bg-brand-300" style="height: 65%"></div>
            <div class="flex-1 rounded-t bg-brand-200" style="height: 85%"></div>
            <div class="flex-1 rounded-t bg-brand-300" style="height: 95%"></div>
            <div class="flex-1 rounded-t bg-brand-400" style="height: 78%"></div>
            <div class="flex-1 rounded-t bg-brand-500" style="height: 88%"></div>
            <div class="flex-1 rounded-t bg-brand-400" style="height: 72%"></div>
            <div class="flex-1 rounded-t bg-brand-300" style="height: 82%"></div>
          </div>
          <div class="mt-2 flex justify-between text-xs text-surface-400">
            <span>Jun 1</span>
            <span>Jun 15</span>
            <span>Jun 30</span>
          </div>
        </div>

        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <h3 class="mb-4 font-semibold text-surface-900">Provider comparison</h3>
          <div class="space-y-4">
            <div>
              <div class="mb-1 flex justify-between text-sm"><span class="text-surface-600">OpenAI</span><span class="text-surface-500">243ms &middot; 0.1% errors</span></div>
              <div class="h-2 rounded-full bg-surface-200"><div class="h-2 w-4/5 rounded-full bg-brand-500"></div></div>
            </div>
            <div>
              <div class="mb-1 flex justify-between text-sm"><span class="text-surface-600">Azure</span><span class="text-surface-500">312ms &middot; 0.3% errors</span></div>
              <div class="h-2 rounded-full bg-surface-200"><div class="h-2 w-3/5 rounded-full bg-brand-400"></div></div>
            </div>
            <div>
              <div class="mb-1 flex justify-between text-sm"><span class="text-surface-600">HuggingFace</span><span class="text-surface-500">1.2s &middot; 2.1% errors</span></div>
              <div class="h-2 rounded-full bg-surface-200"><div class="h-2 w-2/5 rounded-full bg-brand-300"></div></div>
            </div>
            <div>
              <div class="mb-1 flex justify-between text-sm"><span class="text-surface-600">LLM (GPT-4o)</span><span class="text-surface-500">1.8s &middot; 0.5% errors</span></div>
              <div class="h-2 rounded-full bg-surface-200"><div class="h-2 w-1/3 rounded-full bg-brand-300"></div></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Dashboard Features -->
  <section class="bg-surface-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">Everything at your fingertips</h2>
        <p class="mt-4 text-lg text-surface-500">Manage your moderation operations from one place. Available on self-hosted and SaaS.</p>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-xl border border-surface-200 bg-white p-6">
          <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100 text-brand-600">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7h3a2 2 0 012 2v10a2 2 0 01-2 2H6a2 2 0 01-2-2V9a2 2 0 012-2h3m0-4h6v4H9V3z"/></svg>
          </div>
          <h3 class="font-semibold text-surface-900">Access Management</h3>
          <p class="mt-1 text-sm text-surface-500">Control who can do what. Create and revoke access keys, set rate limits, and configure BYOK provider keys.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-white p-6">
          <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100 text-brand-600">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
          </div>
          <h3 class="font-semibold text-surface-900">Activity History</h3>
          <p class="mt-1 text-sm text-surface-500">Track every moderation decision. Search and inspect all requests with full provider, score, and outcome details.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-white p-6">
          <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100 text-brand-600">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/></svg>
          </div>
          <h3 class="font-semibold text-surface-900">Service Health</h3>
          <p class="mt-1 text-sm text-surface-500">See which services are operational. Real-time monitoring of latency and error rates across every provider.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-white p-6">
          <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100 text-brand-600">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          </div>
          <h3 class="font-semibold text-surface-900">Performance Reports</h3>
          <p class="mt-1 text-sm text-surface-500">Understand your moderation volume and trends. Track flagged rates, provider performance, and costs. Exportable for audits.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-white p-6">
          <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100 text-brand-600">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          </div>
          <h3 class="font-semibold text-surface-900">Policies & Integrations</h3>
          <p class="mt-1 text-sm text-surface-500">Manage your moderation settings and platform connections. Configure auto-actions and thresholds from the console.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-white p-6">
          <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100 text-brand-600">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="font-semibold text-surface-900">Configuration</h3>
          <p class="mt-1 text-sm text-surface-500">Instance settings for rate limits, data retention, allowed origins, and provider configuration.</p>
        </div>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>