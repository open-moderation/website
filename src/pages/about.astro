---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';

const aboutJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Logora",
  "description": "Creator of OpenModeration, the open-source moderation platform.",
  "url": "https://www.openmoderation.com",
};
---

<BaseLayout title="About &mdash; OpenModeration" description="OpenModeration is built by Logora. Our mission is to make content moderation an open, standardized infrastructure layer." jsonLd={aboutJsonLd}>
  <section class="bg-gradient-to-b from-brand-50 to-white py-20">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold tracking-tight text-surface-900 sm:text-5xl">About</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-surface-500">
        We're building the standardized infrastructure layer for content moderation.
      </p>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="prose prose-surface mx-auto">
        <h2 class="text-2xl font-bold text-surface-900">Our mission</h2>
        <p class="mt-4 text-lg text-surface-500">
          Every online platform &mdash; from small forums to social networks with millions of users &mdash;
          should be able to moderate content with a single API call, using the best AI models available,
          without proprietary lock-in.
        </p>
        <p class="mt-4 text-lg text-surface-500">
          We believe content moderation is becoming as essential as authentication or payments.
          It should be a standardized infrastructure layer, not a custom build for every company.
        </p>

        <h2 class="mt-12 text-2xl font-bold text-surface-900">Why open source?</h2>
        <p class="mt-4 text-lg text-surface-500">
          Moderation is trust. You can't trust a black box. By making OpenModeration fully open source
          under AGPL v3, we ensure that every line of code is auditable, that there are no hidden agendas,
          and that the platform belongs to the community.
        </p>
        <p class="mt-4 text-lg text-surface-500">
          Our business model follows the open-core pattern proven by PostHog, Sentry, and Supabase:
          the core product is free and open source. A managed cloud version adds convenience, support,
          and SLAs for organizations that need it.
        </p>

        <h2 class="mt-12 text-2xl font-bold text-surface-900">Our approach</h2>
        <div class="mt-6 space-y-6">
          <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
            <h3 class="font-semibold text-surface-900">Developer-first design</h3>
            <p class="mt-2 text-sm text-surface-500">Clean APIs, typed responses, comprehensive documentation. Built by developers, for developers.</p>
          </div>
          <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
            <h3 class="font-semibold text-surface-900">Provider agnostic</h3>
            <p class="mt-2 text-sm text-surface-500">We don't favor any provider. Our routing engine picks the best option for each request, and users can always bring their own keys.</p>
          </div>
          <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
            <h3 class="font-semibold text-surface-900">DSA-first compliance</h3>
            <p class="mt-2 text-sm text-surface-500">Built from the ground up with regulatory compliance in mind. Audit trails, data sovereignty, and transparency reporting are core features.</p>
          </div>
          <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
            <h3 class="font-semibold text-surface-900">Self-hosted by default</h3>
            <p class="mt-2 text-sm text-surface-500">The platform runs on your infrastructure with docker-compose up. No data leaves your control unless you choose the managed cloud option.</p>
          </div>
        </div>

        <h2 class="mt-12 text-2xl font-bold text-surface-900">The team</h2>
        <p class="mt-4 text-lg text-surface-500">
          OpenModeration is built by <strong>Logora</strong>. We're a small, focused team
          with deep experience in building APIs, content platforms, and developer tools.
          We're backed by the conviction that content moderation infrastructure should be
          open, standardized, and accessible to every platform.
        </p>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>