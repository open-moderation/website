---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
import CodeBlock from '../../components/CodeBlock.astro';

const useCaseJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "AI Content Moderation for Social Platforms & Communities — OpenModeration",
  "description": "Moderate user-generated content on social platforms, forums, and communities with AI-powered automation. DSA-compliant audit trails and team review dashboards."
};

const forumExample = `// User submits a comment
POST /v1/moderations

{
  "input": "User's comment text...",
  "language": "fr",
  "context": {
    "channel": "general-discussion",
    "author": {
      "id": "user_456",
      "reputation": 0.92
    }
  }
}

// Response: flagged or not flagged
// If flagged -> hide automatically (rule)
// If borderline -> flag for review`;
---

<BaseLayout title="Content Moderation for Social Platforms & Communities" description="Moderate user-generated content on social platforms, forums, and communities with AI-powered automation. Real-time moderation, batch back-moderation, and DSA-compliant audit trails." canonical="https://www.openmoderation.com/use-cases/social-platforms" jsonLd={useCaseJsonLd}>
  <section class="bg-gradient-to-b from-brand-50 to-white py-20">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-surface-200 bg-white px-4 py-1.5 text-sm text-surface-600">
        Use Case
      </div>
      <h1 class="text-4xl font-bold tracking-tight text-surface-900 sm:text-5xl">AI Content Moderation for Social Platforms</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-surface-500">
        Protect your community at scale. Automatically moderate comments, posts, and messages while empowering your Trust & Safety team with a dedicated review dashboard.
      </p>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-16 grid gap-8 md:grid-cols-3">
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <h3 class="text-lg font-semibold text-surface-900">The Challenge</h3>
          <p class="mt-2 text-sm text-surface-600">Social platforms face a constant influx of user-generated content. Manual moderation cannot scale, and rigid keyword filters create too many false positives, frustrating your community.</p>
        </div>
        <div class="rounded-xl border border-brand-200 bg-brand-50 p-6 shadow-sm">
          <h3 class="text-lg font-semibold text-brand-700">The OpenModeration Solution</h3>
          <p class="mt-2 text-sm text-surface-700">A complete moderation harness. Context-aware AI analyzes content in real-time, while a no-code rule engine automatically hides high-risk posts. Borderline cases are seamlessly routed to your human moderators.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <h3 class="text-lg font-semibold text-surface-900">The Result</h3>
          <p class="mt-2 text-sm text-surface-600">Drastically reduce the volume of content requiring manual review. Maintain DSA compliance with full, exportable audit trails, and foster a safer, more engaged community.</p>
        </div>
      </div>

      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <h2 class="text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">Moderate every interaction point</h2>
          <p class="mt-4 text-lg text-surface-500">
            Communities that fail to act face regulatory fines and user churn. OpenModeration provides the tools to stay compliant and safe.
          </p>
          <div class="mt-8 space-y-3">
            <div class="rounded-lg border border-surface-200 bg-surface-50 p-4">
              <p class="text-sm font-medium text-surface-900">Real-time comment moderation</p>
              <p class="mt-1 text-xs text-surface-500">Analyze content before it appears. Route to the best AI provider for your community's specific language.</p>
            </div>
            <div class="rounded-lg border border-surface-200 bg-surface-50 p-4">
              <p class="text-sm font-medium text-surface-900">Back-moderation of existing content</p>
              <p class="mt-1 text-xs text-surface-500">Submit up to 10,000 items in a single batch. Clean up months of historical content in minutes.</p>
            </div>
            <div class="rounded-lg border border-surface-200 bg-surface-50 p-4">
              <p class="text-sm font-medium text-surface-900">Automated enforcement & human review</p>
              <p class="mt-1 text-xs text-surface-500">Hide hate speech automatically. Flag borderline cases for your team. Every action is logged for compliance.</p>
            </div>
          </div>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-8">
          <h4 class="mb-3 text-sm font-semibold text-surface-900">How it works for a forum</h4>
          <CodeBlock code={forumExample} lang="bash" />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-surface-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">Why social platforms choose OpenModeration</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-3">
        <div class="rounded-xl border border-surface-200 bg-white p-6">
          <h3 class="font-semibold text-surface-900">Multi-language support</h3>
          <p class="mt-2 text-sm text-surface-500">Route English to OpenAI, French to Mistral, German to Azure. Each content item gets the best provider for its language.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-white p-6">
          <h3 class="font-semibold text-surface-900">Real-time performance</h3>
          <p class="mt-2 text-sm text-surface-500">Sub-300ms typical latency. Fast enough for inline comment moderation without degrading user experience.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-white p-6">
          <h3 class="font-semibold text-surface-900">DSA-ready audit trail</h3>
          <p class="mt-2 text-sm text-surface-500">Every moderation decision is logged with full details. Exportable for transparency reports and regulatory audits.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-surface-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-2xl font-bold text-surface-900 sm:text-3xl">Related Resources</h2>
      <div class="grid gap-6 md:grid-cols-3">
        <a href="/blog/dsa-compliance-sme-guide" class="group rounded-xl border border-surface-200 bg-white p-6 transition hover:shadow-md">
          <div class="mb-2 text-xs font-medium text-brand-600">Guide</div>
          <h3 class="text-lg font-semibold text-surface-900 group-hover:text-brand-600">DSA Compliance for Small and Medium Platforms</h3>
          <p class="mt-2 text-sm text-surface-500">Practical steps for communities to meet 2026 DSA requirements with open-source tools.</p>
        </a>
        <a href="/alternatives/perspective-api" class="group rounded-xl border border-surface-200 bg-white p-6 transition hover:shadow-md">
          <div class="mb-2 text-xs font-medium text-brand-600">Comparison</div>
          <h3 class="text-lg font-semibold text-surface-900 group-hover:text-brand-600">OpenModeration vs Perspective API</h3>
          <p class="mt-2 text-sm text-surface-500">Why a complete moderation harness beats a sunset API for community forums.</p>
        </a>
        <a href="/features" class="group rounded-xl border border-surface-200 bg-white p-6 transition hover:shadow-md">
          <div class="mb-2 text-xs font-medium text-brand-600">Platform</div>
          <h3 class="text-lg font-semibold text-surface-900 group-hover:text-brand-600">Explore All Features</h3>
          <p class="mt-2 text-sm text-surface-500">Discover the no-code rule engine, team management, and automated workflows.</p>
        </a>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>