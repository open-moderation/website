---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
import CodeBlock from '../../components/CodeBlock.astro';

const useCaseJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "AI Content Moderation for Marketplaces & E-Commerce — OpenModeration",
  "description": "Moderate product listings, reviews, and seller messages on e-commerce and classifieds platforms with AI. DSA-compliant, open-source moderation platform."
};

const batchModerationExample = `POST /v1/moderations/batch

{
  "items": [{
    "input": "Listing description...",
    "custom_id": "listing_1"
  }, {
    "input": "Another listing...",
    "custom_id": "listing_2"
  }],
  "webhook_url": "https://myapp.com/webhook/batch"
}`;
---

<BaseLayout title="Content Moderation for Marketplaces & E-Commerce" description="Moderate product listings, reviews, and seller messages with AI. Keep your marketplace safe, compliant, and trustworthy." canonical="https://openmoderation.com/use-cases/marketplaces" jsonLd={useCaseJsonLd}>
  <section class="bg-gradient-to-b from-brand-50 to-white py-20">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-surface-200 bg-white px-4 py-1.5 text-sm text-surface-600">Use Case</div>
      <h1 class="text-4xl font-bold tracking-tight text-surface-900 sm:text-5xl">AI Content Moderation for Marketplaces</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-surface-500">Keep your e-commerce platform safe and compliant. Automatically moderate product listings, user reviews, and seller communications at scale.</p>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-16 grid gap-8 md:grid-cols-3">
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <h3 class="text-lg font-semibold text-surface-900">The Challenge</h3>
          <p class="mt-2 text-sm text-surface-600">A single scam listing, fake review, or fraudulent message can erode months of trust-building. Manual moderation doesn't scale with marketplace growth, and rigid keyword filters create too many false positives.</p>
        </div>
        <div class="rounded-xl border border-brand-200 bg-brand-50 p-6 shadow-sm">
          <h3 class="text-lg font-semibold text-brand-700">The OpenModeration Solution</h3>
          <p class="mt-2 text-sm text-surface-700">A complete moderation harness. Context-aware AI analyzes listings and messages, while a no-code rule engine automatically hides high-risk content. Edge cases are routed to a dedicated review dashboard for your Trust & Safety team.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <h3 class="text-lg font-semibold text-surface-900">The Result</h3>
          <p class="mt-2 text-sm text-surface-600">Drastically reduce the time your team spends on manual reviews. Maintain DSA compliance with full audit trails, and protect your marketplace's reputation with proactive, intelligent moderation.</p>
        </div>
      </div>

      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <h2 class="text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">Moderate every surface of your platform</h2>
          <p class="mt-4 text-lg text-surface-500">Marketplaces need proactive moderation across every user interaction point. OpenModeration handles it all from a single integration.</p>
          <div class="mt-8 space-y-4">
            <div class="flex items-start gap-3">
              <svg class="mt-1 h-5 w-5 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <p class="text-sm text-surface-600"><strong>Product listings:</strong> Block prohibited items, detect scam patterns, and flag misleading descriptions before they go live.</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="mt-1 h-5 w-5 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <p class="text-sm text-surface-600"><strong>Reviews & ratings:</strong> Detect fake reviews, hate speech, and spam in user feedback to maintain authentic community trust.</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="mt-1 h-5 w-5 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <p class="text-sm text-surface-600"><strong>Seller messages:</strong> Monitor buyer-seller communications for harassment, off-platform diversion, and fraud attempts.</p>
            </div>
          </div>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-8">
          <h4 class="mb-3 text-sm font-semibold text-surface-900">Batch back-moderation for existing content</h4>
          <CodeBlock code={batchModerationExample} lang="json" />
          <p class="mt-3 text-xs text-surface-500">Process up to 10,000 existing listings asynchronously. Results and automated actions are delivered via webhook.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-surface-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-2xl font-bold text-surface-900 sm:text-3xl">Related Resources</h2>
      <div class="grid gap-6 md:grid-cols-3">
        <a href="/blog/dsa-compliance-sme-guide" class="group rounded-xl border border-surface-200 bg-white p-6 transition hover:shadow-md">
          <div class="mb-2 text-xs font-medium text-brand-600">Guide</div>
          <h3 class="text-lg font-semibold text-surface-900 group-hover:text-brand-600">DSA Compliance for Small and Medium Platforms</h3>
          <p class="mt-2 text-sm text-surface-500">Practical steps for marketplaces to meet 2026 DSA requirements with open-source tools.</p>
        </a>
        <a href="/alternatives/azure-content-safety" class="group rounded-xl border border-surface-200 bg-white p-6 transition hover:shadow-md">
          <div class="mb-2 text-xs font-medium text-brand-600">Comparison</div>
          <h3 class="text-lg font-semibold text-surface-900 group-hover:text-brand-600">OpenModeration vs Azure Content Safety</h3>
          <p class="mt-2 text-sm text-surface-500">Why a complete moderation harness beats a standalone API for e-commerce platforms.</p>
        </a>
        <a href="/features" class="group rounded-xl border border-surface-200 bg-white p-6 transition hover:shadow-md">
          <div class="mb-2 text-xs font-medium text-brand-600">Platform</div>
          <h3 class="text-lg font-semibold text-surface-900 group-hover:text-brand-600">Explore All Features</h3>
          <p class="mt-2 text-sm text-surface-500">Discover the no-code rule engine, team management, and automated workflows.</p>
        </a>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>