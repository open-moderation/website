---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
import CodeBlock from '../../components/CodeBlock.astro';

const useCaseJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Content Moderation for Marketplaces &mdash; OpenModeration",
  "description": "Moderate product listings, reviews, and seller messages on e-commerce and classifieds platforms. DSA-compliant moderation.",
};

const batchModerationExample = `POST /v1/moderations/batch

{
  "items": [{
    "input": "Listing description...",
    "custom_id": "listing_1"
  }, {
    "input": "Another listing...",
    "custom_id": "listing_2"
  }],
  "webhook_url": "https://myapp.com/webhook/batch"
}`;
---

<BaseLayout title="Content Moderation for Marketplaces & E-Commerce" description="Moderate product listings, reviews, and seller messages with AI. Keep your marketplace safe, compliant, and trustworthy." canonical="https://openmoderation.com/use-cases/marketplaces" jsonLd={useCaseJsonLd}>
  <section class="bg-gradient-to-b from-brand-50 to-white py-20">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-surface-200 bg-white px-4 py-1.5 text-sm text-surface-600">Use Case</div>
      <h1 class="text-4xl font-bold tracking-tight text-surface-900 sm:text-5xl">Marketplaces & E-Commerce</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-surface-500">Keep your marketplace safe. Moderate listings, reviews, and seller communications at scale.</p>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <h2 class="text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">Trust is your marketplace currency</h2>
          <p class="mt-4 text-lg text-surface-500">A single scam listing or fraudulent review can erode months of trust-building. Marketplaces need proactive moderation across every surface.</p>
          <div class="mt-8 space-y-4">
            <div class="flex items-start gap-3">
              <svg class="mt-1 h-5 w-5 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <p class="text-sm text-surface-600"><strong>Product listings:</strong> Block prohibited items, detect scam listings, flag misleading descriptions.</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="mt-1 h-5 w-5 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <p class="text-sm text-surface-600"><strong>Reviews & ratings:</strong> Detect fake reviews, hate speech, and spam in user feedback.</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="mt-1 h-5 w-5 shrink-0 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <p class="text-sm text-surface-600"><strong>Seller messages:</strong> Moderate buyer-seller communications for harassment and fraud attempts.</p>
            </div>
          </div>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-8">
          <h4 class="mb-3 text-sm font-semibold text-surface-900">Batch back-moderation</h4>
          <CodeBlock code={batchModerationExample} lang="json" />
          <p class="mt-3 text-xs text-surface-500">Process up to 10,000 listings asynchronously. Results delivered via webhook.</p>
        </div>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>