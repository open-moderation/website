---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
import CodeBlock from '../../components/CodeBlock.astro';

const useCaseJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "AI Chat Moderation for Gaming & Esports — OpenModeration",
  "description": "Moderate in-game chat, player messages, and user reports in real time. Multi-language, low-latency, and automated enforcement for gaming communities."
};

const discordRuleExample = `{
  "name": "Auto-delete hate speech",
  "priority": 10,
  "conditions": [{
    "category": "hate",
    "operator": "gte",
    "score": 0.7
  }],
  "actions": [{
    "type": "delete_message"
  }, {
    "type": "flag_for_review"
  }]
}`;
---

<BaseLayout title="Game Chat Moderation &mdash; Real-Time AI Moderation for Gaming" description="Moderate in-game chat, player messages, and user reports. Low-latency, multi-language, auto-enforcement with Discord connector." canonical="https://www.openmoderation.com/use-cases/gaming" jsonLd={useCaseJsonLd}>
  <section class="bg-gradient-to-b from-brand-50 to-white py-20">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-surface-200 bg-white px-4 py-1.5 text-sm text-surface-600">Use Case</div>
      <h1 class="text-4xl font-bold tracking-tight text-surface-900 sm:text-5xl">AI Chat Moderation for Gaming</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-surface-500">Real-time chat moderation for multiplayer games and Discord communities. Keep your players engaged and your community safe from toxicity.</p>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-16 grid gap-8 md:grid-cols-3">
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <h3 class="text-lg font-semibold text-surface-900">The Challenge</h3>
          <p class="mt-2 text-sm text-surface-600">Toxic behavior is the #1 reason players quit multiplayer games. A single toxic player can ruin the experience for an entire lobby, and manual moderation is impossible at scale.</p>
        </div>
        <div class="rounded-xl border border-brand-200 bg-brand-50 p-6 shadow-sm">
          <h3 class="text-lg font-semibold text-brand-700">The OpenModeration Solution</h3>
          <p class="mt-2 text-sm text-surface-700">Sub-300ms latency moderation that integrates directly with Discord and in-game chat APIs. Context-aware AI detects toxicity in real-time, while automated rules instantly delete or flag violations.</p>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
          <h3 class="text-lg font-semibold text-surface-900">The Result</h3>
          <p class="mt-2 text-sm text-surface-600">Protect your player retention and community reputation. Automate the enforcement of your community guidelines across all languages, without disrupting the gameplay experience.</p>
        </div>
      </div>

      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <h2 class="text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">Moderate every chat channel</h2>
          <p class="mt-4 text-lg text-surface-500">OpenModeration integrates seamlessly into your existing gaming infrastructure.</p>
          <div class="mt-8 space-y-3">
            <div class="rounded-lg border border-surface-200 bg-surface-50 p-4">
              <p class="text-sm font-semibold text-surface-900">Discord integration</p>
              <p class="mt-1 text-xs text-surface-500">Connect your Discord server. Auto-delete messages that violate your community rules before they escalate.</p>
            </div>
            <div class="rounded-lg border border-surface-200 bg-surface-50 p-4">
              <p class="text-sm font-semibold text-surface-900">In-game chat API</p>
              <p class="mt-1 text-xs text-surface-500">Send chat messages to POST /v1/moderations before displaying. Flag or block toxic messages in real time.</p>
            </div>
            <div class="rounded-lg border border-surface-200 bg-surface-50 p-4">
              <p class="text-sm font-semibold text-surface-900">Multi-language toxicity detection</p>
              <p class="mt-1 text-xs text-surface-500">Route English chat to OpenAI, Korean to Azure, Spanish to Mistral. Every language covered with high accuracy.</p>
            </div>
          </div>
        </div>
        <div class="rounded-xl border border-surface-200 bg-surface-50 p-8">
          <h4 class="mb-3 text-sm font-semibold text-surface-900">Discord rule example</h4>
          <CodeBlock code={discordRuleExample} lang="json" />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-surface-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-2xl font-bold text-surface-900 sm:text-3xl">Related Resources</h2>
      <div class="grid gap-6 md:grid-cols-3">
        <a href="/blog/ai-content-moderation-developer-guide" class="group rounded-xl border border-surface-200 bg-white p-6 transition hover:shadow-md">
          <div class="mb-2 text-xs font-medium text-brand-600">Guide</div>
          <h3 class="text-lg font-semibold text-surface-900 group-hover:text-brand-600">Content Moderation for AI Applications</h3>
          <p class="mt-2 text-sm text-surface-500">Best practices for filtering inputs and outputs in real-time interactive environments.</p>
        </a>
        <a href="/alternatives/azure-content-safety" class="group rounded-xl border border-surface-200 bg-white p-6 transition hover:shadow-md">
          <div class="mb-2 text-xs font-medium text-brand-600">Comparison</div>
          <h3 class="text-lg font-semibold text-surface-900 group-hover:text-brand-600">OpenModeration vs Azure Content Safety</h3>
          <p class="mt-2 text-sm text-surface-500">Why a complete moderation harness beats a standalone API for gaming communities.</p>
        </a>
        <a href="/features" class="group rounded-xl border border-surface-200 bg-white p-6 transition hover:shadow-md">
          <div class="mb-2 text-xs font-medium text-brand-600">Platform</div>
          <h3 class="text-lg font-semibold text-surface-900 group-hover:text-brand-600">Explore All Features</h3>
          <p class="mt-2 text-sm text-surface-500">Discover the no-code rule engine, team management, and automated workflows.</p>
        </a>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>