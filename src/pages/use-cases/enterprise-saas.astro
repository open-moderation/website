---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';

const useCaseJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Enterprise SaaS Content Moderation &mdash; OpenModeration",
  "description": "Meet enterprise compliance requirements with open-source, self-hosted content moderation. DSA-ready, SOC 2-ready, full audit trails.",
};

---

<BaseLayout title="Enterprise SaaS Content Moderation &mdash; Compliance & Scalability" description="Enterprise-grade content moderation for B2B SaaS platforms. Self-hosted, DSA-compliant, SOC 2-ready. Full audit trails and data sovereignty." canonical="https://openmoderation.com/use-cases/enterprise-saas" jsonLd={useCaseJsonLd}>
  <section class="bg-gradient-to-b from-brand-50 to-white py-20">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-surface-200 bg-white px-4 py-1.5 text-sm text-surface-600">Use Case</div>
      <h1 class="text-4xl font-bold tracking-tight text-surface-900 sm:text-5xl">Enterprise SaaS</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-surface-500">Meet enterprise compliance requirements with self-hosted, auditable content moderation.</p>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <h2 class="text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">Enterprise compliance is non-negotiable</h2>
          <p class="mt-4 text-lg text-surface-500">B2B SaaS platforms that host user-generated content need provable, auditable moderation. Enterprise customers demand it. Regulators require it.</p>
          <p class="mt-4 text-lg text-surface-500">OpenModeration is the only enterprise-ready moderation platform that is fully open source, self-hostable, and DSA-compliant.</p>
          <div class="mt-8 grid grid-cols-2 gap-4">
            <div class="rounded-lg border border-surface-200 p-4 text-center">
              <p class="text-2xl font-bold text-surface-900">100%</p>
              <p class="text-xs text-surface-500">Data sovereignty (self-hosted)</p>
            </div>
            <div class="rounded-lg border border-surface-200 p-4 text-center">
              <p class="text-2xl font-bold text-surface-900">AGPL v3</p>
              <p class="text-xs text-surface-500">Fully auditable code</p>
            </div>
            <div class="rounded-lg border border-surface-200 p-4 text-center">
              <p class="text-2xl font-bold text-surface-900">&lt;300ms</p>
              <p class="text-xs text-surface-500">P50 latency per request</p>
            </div>
            <div class="rounded-lg border border-surface-200 p-4 text-center">
              <p class="text-2xl font-bold text-surface-900">10K</p>
              <p class="text-xs text-surface-500">Items per batch request</p>
            </div>
          </div>
        </div>
        <div class="space-y-4">
          <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
            <h3 class="font-semibold text-surface-900">Self-hosted deployment</h3>
            <p class="mt-2 text-sm text-surface-500">Deploy with docker-compose up on your infrastructure. PostgreSQL + Redis. No external API dependencies for the platform itself.</p>
          </div>
          <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
            <h3 class="font-semibold text-surface-900">Data retention controls</h3>
            <p class="mt-2 text-sm text-surface-500">Configurable retention policies: 0, 7, 30, or 90 days. Encrypted storage for sensitive content. Full deletion on request.</p>
          </div>
          <div class="rounded-xl border border-surface-200 bg-surface-50 p-6">
            <h3 class="font-semibold text-surface-900">SOC 2 ready</h3>
            <p class="mt-2 text-sm text-surface-500">Audit logs, access controls, encryption at rest, and encryption in transit. Built for SOC 2 certification workflows.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>