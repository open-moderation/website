---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';

const costs = [
  { item: 'Initial engineering (3-8 engineers, 6-12 months)', build: '$500k - $1.5M', buy: '$0' },
  { item: 'Ongoing maintenance (0.5-1 FTE)', build: '$150k - $400k/yr', buy: '$0' },
  { item: 'Security incidents & outages', build: '$20k - $80k per incident', buy: '$0 (community)' },
  { item: 'Infrastructure (servers, DB, Redis)', build: '$500 - $5K/mo', buy: 'Your existing infra' },
  { item: 'Compliance updates per regulation change', build: '$30k - $100k', buy: '$0 (built-in)' },
  { item: 'On-call rotations', build: '$30k - $60k/yr', buy: '$0' },
];
---

<BaseLayout
  title="Build vs Buy - OpenModeration"
  description="Compare the true cost of building in-house moderation infrastructure versus using OpenModeration. Engineering time, maintenance, and feature parity analysis."
>
  <section class="bg-gradient-to-b from-brand-50 to-white py-20">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-surface-200 bg-white px-4 py-1.5 text-sm text-surface-600">
        Build vs Buy
      </div>
      <h1 class="text-4xl font-bold tracking-tight text-surface-900 sm:text-5xl">Build vs Buy: The true cost of moderation infrastructure</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-surface-500">
        Before you decide to build your own moderation pipeline, understand what it really costs.
      </p>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 lg:grid-cols-2">
        <div class="rounded-xl border-2 border-surface-200 bg-surface-50 p-8">
          <h2 class="text-xl font-bold text-surface-900">Build your own</h2>
          <div class="mt-6 space-y-4">
            <div class="border-b border-surface-200 pb-4">
              <p class="text-sm text-surface-500">Time to MVP</p>
              <p class="text-2xl font-bold text-surface-900">6-12 months</p>
            </div>
            <div class="border-b border-surface-200 pb-4">
              <p class="text-sm text-surface-500">Engineering cost</p>
              <p class="text-2xl font-bold text-surface-900">$1-2M</p>
              <p class="text-xs text-surface-400">at $200k/yr fully loaded per engineer</p>
            </div>
            <div class="border-b border-surface-200 pb-4">
              <p class="text-sm text-surface-500">Maintenance</p>
              <p class="text-2xl font-bold text-surface-900">Ongoing forever</p>
              <p class="text-xs text-surface-400">50% of eng time on moderation infrastructure</p>
            </div>
            <div>
              <p class="text-sm text-surface-500">On-call</p>
              <p class="text-2xl font-bold text-surface-900">24/7 rotations</p>
            </div>
          </div>
        </div>
        <div class="rounded-xl border-2 border-brand-500 bg-brand-50 p-8">
          <div class="mb-2 inline-flex items-center gap-2 rounded-full bg-brand-100 px-3 py-1 text-xs font-semibold text-brand-700">Recommended</div>
          <h2 class="text-xl font-bold text-surface-900">OpenModeration</h2>
          <div class="mt-6 space-y-4">
            <div class="border-b border-brand-200 pb-4">
              <p class="text-sm text-surface-500">Time to MVP</p>
              <p class="text-2xl font-bold text-surface-900">5 minutes</p>
              <p class="text-xs text-surface-400">docker-compose up</p>
            </div>
            <div class="border-b border-brand-200 pb-4">
              <p class="text-sm text-surface-500">Engineering cost</p>
              <p class="text-2xl font-bold text-accent-600">$0</p>
              <p class="text-xs text-surface-400">AGPL v3, free forever</p>
            </div>
            <div class="border-b border-brand-200 pb-4">
              <p class="text-sm text-surface-500">Maintenance</p>
              <p class="text-2xl font-bold text-surface-900">Zero</p>
              <p class="text-xs text-surface-400">Community maintains, you deploy</p>
            </div>
            <div>
              <p class="text-sm text-surface-500">On-call</p>
              <p class="text-2xl font-bold text-surface-900">Not needed</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-surface-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-2xl font-bold text-surface-900 sm:text-3xl">Year 1 cost breakdown</h2>
      <div class="overflow-x-auto rounded-xl border border-surface-200">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="bg-surface-100">
              <th class="px-6 py-4 font-semibold text-surface-900">Cost item</th>
              <th class="px-6 py-4 font-semibold text-red-600">Build</th>
              <th class="px-6 py-4 font-semibold text-accent-600">OpenModeration</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-surface-200 bg-white">
            {costs.map((c) => (
              <tr>
                <td class="px-6 py-4 text-surface-600">{c.item}</td>
                <td class="px-6 py-4 text-surface-900">{c.build}</td>
                <td class="px-6 py-4 font-medium text-accent-600">{c.buy}</td>
              </tr>
            ))}
            <tr class="bg-surface-50">
              <td class="px-6 py-4 font-bold text-surface-900">Year 1 total</td>
              <td class="px-6 py-4 font-bold text-red-600">$1,000,000+</td>
              <td class="px-6 py-4 font-bold text-accent-600">$0</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="mt-4 text-xs text-surface-400">Estimates based on US-based senior engineering at $200k/yr fully loaded. Your mileage may vary.</p>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-2xl font-bold text-surface-900 sm:text-3xl">What you get vs what you build</h2>
      <div class="overflow-x-auto rounded-xl border border-surface-200">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="bg-surface-100">
              <th class="px-6 py-4 font-semibold text-surface-900">Feature</th>
              <th class="px-6 py-4 font-semibold text-red-600">Building in-house</th>
              <th class="px-6 py-4 font-semibold text-accent-600">OpenModeration</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-surface-200 bg-white">
            <tr><td class="px-6 py-4 text-surface-600">Multi-provider support</td><td class="px-6 py-4 text-surface-500">3-6 months to integrate 2 providers</td><td class="px-6 py-4 text-accent-600">9+ providers included</td></tr>
            <tr><td class="px-6 py-4 text-surface-600">Unified response format</td><td class="px-6 py-4 text-surface-500">Custom normalization per provider</td><td class="px-6 py-4 text-accent-600">Standardized out of the box</td></tr>
            <tr><td class="px-6 py-4 text-surface-600">Smart routing</td><td class="px-6 py-4 text-surface-500">Build routing logic from scratch</td><td class="px-6 py-4 text-accent-600">Config-based routing</td></tr>
            <tr><td class="px-6 py-4 text-surface-600">Admin dashboard</td><td class="px-6 py-4 text-surface-500">Build React/Vue dashboard</td><td class="px-6 py-4 text-accent-600">Included, ready to use</td></tr>
            <tr><td class="px-6 py-4 text-surface-600">Action engine</td><td class="px-6 py-4 text-surface-500">Build rules engine + webhooks</td><td class="px-6 py-4 text-accent-600">Built-in rule builder</td></tr>
            <tr><td class="px-6 py-4 text-surface-600">Social connectors</td><td class="px-6 py-4 text-surface-500">Integrate each platform individually</td><td class="px-6 py-4 text-accent-600">Facebook, YouTube, Discord included</td></tr>
            <tr><td class="px-6 py-4 text-surface-600">Audit trail</td><td class="px-6 py-4 text-surface-500">Design logging system from scratch</td><td class="px-6 py-4 text-accent-600">DSA-compliant audit logs</td></tr>
            <tr><td class="px-6 py-4 text-surface-600">Batch moderation</td><td class="px-6 py-4 text-surface-500">Build async processing + webhooks</td><td class="px-6 py-4 text-accent-600">Native batch API</td></tr>
            <tr><td class="px-6 py-4 text-surface-600">API key management</td><td class="px-6 py-4 text-surface-500">Implement auth + rate limiting</td><td class="px-6 py-4 text-accent-600">Built-in key management</td></tr>
            <tr><td class="px-6 py-4 text-surface-600">Docker deployment</td><td class="px-6 py-4 text-surface-500">Containerize and orchestrate</td><td class="px-6 py-4 text-accent-600">docker-compose up</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="bg-ink-900 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-2xl font-bold text-white sm:text-3xl">The hidden costs of building in-house</h2>
      </div>
      <div class="mt-8 grid gap-6 md:grid-cols-2">
        <div class="rounded-xl border border-ink-700 bg-ink-800 p-6">
          <h3 class="font-semibold text-white">On-call rotations</h3>
          <p class="mt-2 text-sm text-surface-400">Who gets paged at 3am when the pipeline goes down? In-house means your team owns the pager for yet another critical system.</p>
        </div>
        <div class="rounded-xl border border-ink-700 bg-ink-800 p-6">
          <h3 class="font-semibold text-white">Provider API changes</h3>
          <p class="mt-2 text-sm text-surface-400">Providers change schemas, deprecate models, update taxonomies without warning. Every change is a fire drill for in-house systems.</p>
        </div>
        <div class="rounded-xl border border-ink-700 bg-ink-800 p-6">
          <h3 class="font-semibold text-white">Compliance drift</h3>
          <p class="mt-2 text-sm text-surface-400">DSA, OSA, and other regulations evolve. In-house teams must track legislation and implement audit trail changes. OpenModeration is built DSA-compliant from day one.</p>
        </div>
        <div class="rounded-xl border border-ink-700 bg-ink-800 p-6">
          <h3 class="font-semibold text-white">Infrastructure scaling</h3>
          <p class="mt-2 text-sm text-surface-400">Your moderation needs grow faster than expected. In-house systems that handle 100 req/min break at 10,000 req/min. OpenModeration is designed for horizontal scaling.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-surface-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-2xl font-bold text-surface-900 sm:text-3xl">When to build vs when to buy</h2>
      <div class="grid gap-8 md:grid-cols-2">
        <div class="rounded-xl border border-surface-200 bg-white p-6">
          <h3 class="flex items-center gap-2 text-lg font-semibold text-red-600">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            Build when...
          </h3>
          <ul class="mt-4 space-y-2 text-sm text-surface-600">
            <li>Moderation is your core product differentiator</li>
            <li>You have 3+ engineers to dedicate for 6+ months</li>
            <li>You need proprietary moderation algorithms</li>
            <li>You have ex-regulators on staff for compliance</li>
          </ul>
        </div>
        <div class="rounded-xl border border-brand-200 bg-brand-50 p-6">
          <h3 class="flex items-center gap-2 text-lg font-semibold text-accent-600">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Buy OpenModeration when...
          </h3>
          <ul class="mt-4 space-y-2 text-sm text-surface-600">
            <li>You want moderation working today, not in 6 months</li>
            <li>Your engineering team should focus on your product</li>
            <li>You want multi-provider flexibility without lock-in</li>
            <li>You need DSA compliance without hiring compliance experts</li>
            <li>You want to keep your data on your infrastructure</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="Stop building. Start moderating."
    subtitle="Deploy OpenModeration in 5 minutes with Docker. Free, open source, no lock-in."
    buttonText="Start free trial"
    buttonHref="https://app.openmoderation.com"
  />
</BaseLayout>