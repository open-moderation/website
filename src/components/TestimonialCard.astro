---
export interface Props {
  quote: string;
  author: string;
  role: string;
  company?: string;
  avatar?: string;
}

const { quote, author, role, company } = Astro.props;
---

<figure class="rounded-xl border border-surface-200 bg-white p-6 shadow-sm">
  <svg class="mb-3 h-6 w-6 text-brand-200" fill="currentColor" viewBox="0 0 24 24">
    <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311C9.591 11.69 11 13.166 11 15c0 1.933-1.567 3.5-3.5 3.5-1.271 0-2.404-.619-2.917-1.179zM15.583 17.321C14.553 16.227 14 15 14 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311C20.591 11.69 22 13.166 22 15c0 1.933-1.567 3.5-3.5 3.5-1.271 0-2.404-.619-2.917-1.179z"/>
  </svg>
  <blockquote class="text-sm leading-relaxed text-surface-600">{quote}</blockquote>
  <figcaption class="mt-4 flex items-center gap-3 border-t border-surface-100 pt-4">
    <div class="flex h-9 w-9 items-center justify-center rounded-full bg-brand-100 text-xs font-bold text-brand-600">
      {author.split(' ').map(n => n[0]).join('').slice(0, 2)}
    </div>
    <div>
      <p class="text-sm font-medium text-surface-900">{author}</p>
      <p class="text-xs text-surface-500">{role}{company ? `, ${company}` : ''}</p>
    </div>
  </figcaption>
</figure>