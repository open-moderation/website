---
export interface Props {
  title: string;
  subtitle?: string;
  centered?: boolean;
  light?: boolean;
}

const { title, subtitle, centered = true, light = false } = Astro.props;
---

<div class={`mb-12 ${centered ? 'text-center' : ''}`}>
  <h2 class={`text-3xl font-bold tracking-tight sm:text-4xl ${light ? 'text-white' : 'text-surface-900'}`}>
    {title}
  </h2>
  {subtitle && (
    <p class={`mt-4 text-lg ${light ? 'text-surface-300' : 'text-surface-500'} ${centered ? 'mx-auto max-w-2xl' : ''}`}>
      {subtitle}
    </p>
  )}
</div>