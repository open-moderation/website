---
export interface Props {
  items: Array<{ value: string; label: string; prefix?: string }>;
  light?: boolean;
}

const { items, light = false } = Astro.props;
---

<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
  <dl class={`grid gap-px overflow-hidden rounded-xl ${light ? 'divide-white/10 bg-white/10' : 'divide-surface-200 bg-surface-200'} grid-cols-2 sm:grid-cols-4`}>
    {items.map((item) => (
      <div class={`px-6 py-8 text-center ${light ? 'bg-ink-900' : 'bg-white'}`}>
        <dt class={`text-sm font-medium ${light ? 'text-surface-400' : 'text-surface-500'}`}>{item.label}</dt>
        <dd class={`mt-2 text-3xl font-bold tracking-tight ${light ? 'text-coral' : 'text-surface-900'} sm:text-4xl`}>
          {item.prefix}{item.value}
        </dd>
      </div>
    ))}
  </dl>
</div>