---
export interface Props {
  variant?: 'flow' | 'blob' | 'corner';
}

const { variant = 'flow' } = Astro.props;
---

{
  variant === 'flow' && (
    <svg class="pointer-events-none absolute right-0 top-0 -z-10 h-64 w-64 text-brand-50 sm:h-96 sm:w-96" viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M400 0C200 50 100 150 150 300C200 450 350 400 400 350V0Z" fill="currentColor" opacity="0.5" />
      <path d="M400 50C250 80 150 170 180 280C210 390 320 380 400 350V50Z" fill="currentColor" opacity="0.3" />
    </svg>
  )
}
{
  variant === 'blob' && (
    <svg class="pointer-events-none absolute left-0 top-0 -z-10 h-72 w-72 text-brand-50" viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M200 0C300 20 380 100 400 200C420 300 340 380 200 400C60 380 20 280 0 200C-20 120 100 0 200 0Z" fill="currentColor" opacity="0.4" />
    </svg>
  )
}
{
  variant === 'corner' && (
    <svg class="pointer-events-none absolute right-0 top-0 -z-10 h-96 w-96 text-brand-50" viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="350" cy="50" r="200" fill="currentColor" opacity="0.3" />
      <circle cx="300" cy="100" r="140" fill="currentColor" opacity="0.2" />
      <circle cx="270" cy="130" r="80" fill="currentColor" opacity="0.15" />
    </svg>
  )
}