---
export interface Props {
  title?: string;
  subtitle?: string;
  buttonText?: string;
  buttonHref?: string;
  dark?: boolean;
}

const {
  title = 'Ready to simplify your moderation stack?',
  subtitle = 'Get a complete moderation platform with AI, rules, and a human review interface. No complex integrations required.',
  buttonText = 'Try it for free',
  buttonHref = 'https://app.openmoderation.com/signup',
  dark = true,
} = Astro.props;
---

<section class={`relative overflow-hidden ${dark ? 'bg-brand-900' : 'bg-brand-600'}`}>
  {dark && (
    <svg class="pointer-events-none absolute -right-20 -top-20 h-80 w-80 text-surface-800" viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="300" cy="50" r="200" fill="currentColor" opacity="0.3" />
      <circle cx="250" cy="100" r="140" fill="currentColor" opacity="0.2" />
    </svg>
  )}
  <div class="relative mx-auto max-w-4xl px-4 py-20 text-center sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">{title}</h2>
    <p class={`mx-auto mt-4 max-w-2xl text-lg ${dark ? 'text-surface-300' : 'text-brand-100'}`}>{subtitle}</p>
    <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a href={buttonHref} class="inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 text-sm font-semibold text-surface-900 shadow-sm transition hover:bg-surface-100">
        <span>{buttonText}</span>
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
      {!dark && (
        <a href="/docs" class="inline-flex items-center gap-2 rounded-lg border border-white/30 px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/10">
          Read the docs
        </a>
      )}
    </div>
  </div>
</section>