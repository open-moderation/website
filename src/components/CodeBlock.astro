---
export interface Props {
  code: string;
  lang?: string;
}

const { code, lang = 'bash' } = Astro.props;
---

<div class="group relative overflow-hidden rounded-xl border border-surface-200 bg-surface-900 shadow-lg">
  <div class="flex items-center gap-1.5 border-b border-surface-700 px-4 py-3">
    <span class="h-3 w-3 rounded-full bg-surface-500" />
    <span class="h-3 w-3 rounded-full bg-surface-500" />
    <span class="h-3 w-3 rounded-full bg-surface-500" />
    <span class="ml-3 text-xs text-surface-400">{lang}</span>
  </div>
  <pre class="overflow-x-auto p-4 text-sm leading-relaxed"><code class="font-mono text-surface-200">{code}</code></pre>
</div>